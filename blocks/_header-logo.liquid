

{% liquid
  assign block_settings = block.settings
  assign use_inverse_logo = false

  if section.settings.enable_transparent_header_home and template.name == 'index' and section.settings.home_color_scheme == 'inverse'
    assign use_inverse_logo = true
  elsif section.settings.enable_transparent_header_product and template.name == 'product' and section.settings.product_color_scheme == 'inverse'
    assign use_inverse_logo = true
  elsif section.settings.enable_transparent_header_collection and template.name == 'collection' and section.settings.collection_color_scheme == 'inverse'
    assign use_inverse_logo = true
  endif

  if use_inverse_logo
    if settings.logo_inverse != blank
      assign inverse_logo = settings.logo_inverse
    else
      assign inverse_logo = settings.logo
    endif
  endif

  assign alt_text_fallback = 'accessibility.home_logo_alt' | t: store_name: shop.name
%}

{% comment %}
  Output all logo variants, use CSS to hide/show the appropriate one
  based on the .header[transparent] selector
{% endcomment %}
<a
  {% if template.name == 'index' and block_settings.hide_logo_on_home_page %}
    data-hidden-on-home-page
  {% endif %}
  href="{{ routes.root_url }}"
  class="size-style spacing-style header-logo"
  style="
    {% render 'size-style', settings: block_settings %}
    {% render 'spacing-style', settings: block_settings %}
    --font-family: var(--font-body--family);
    --font-style: var(--font-body--style);
    --font-weight: 600;
  "
  {{ block.shopify_attributes }}
>
  {%- comment -%} Custom iMobile Accessories monogram logo (iC, red & black) {%- endcomment -%}
  <span class="im-logo" data-testid="header-logo" aria-label="{{ shop.name | escape }}">
    <svg class="im-logo__badge" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="imlg-{{ block.id }}" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#1a1a1d"/>
          <stop offset="0.55" stop-color="#0d0d0f"/>
          <stop offset="1" stop-color="#3a0510"/>
        </linearGradient>
      </defs>
      <rect x="1.5" y="1.5" width="45" height="45" rx="11" fill="url(#imlg-{{ block.id }})" stroke="#d90429" stroke-width="2"/>
      <circle cx="15.5" cy="14.5" r="3.1" fill="#d90429"/>
      <rect x="12.8" y="20.5" width="5.4" height="15.5" rx="2.6" fill="#ffffff"/>
      <path d="M37.4 18.2a9.4 9.4 0 1 0 0 11.6" fill="none" stroke="#d90429" stroke-width="5.2" stroke-linecap="round"/>
    </svg>
    <span class="im-logo__word">iMobile<b>Accessories</b></span>
  </span>
</a>

{% stylesheet %}
  .header-logo {
    display: flex;
    height: 100%;
    font-size: var(--font-size--md);
    font-family: var(--font-family);
    font-weight: var(--font-weight);
    font-style: var(--font-style);
    color: var(--color-foreground);
    justify-content: center;
    align-items: center;
    text-decoration: none;

    &[data-hidden-on-home-page] {
      display: none;

      #header-component:is(
          [sticky='always']:not([data-scroll-direction='none']),
          [sticky='scroll-up'][data-scroll-direction='up']
        )
        & {
        display: flex;
      }
    }

    @media screen and (max-width: 749px) {
      padding: 0;
    }

    @media screen and (min-width: 750px) {
      flex-shrink: 0;
    }

    &:hover {
      text-decoration: none;
    }
  }

  .im-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .im-logo:hover {
    transform: translateY(-1px);
  }

  .im-logo__badge {
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    filter: drop-shadow(0 4px 10px rgba(217, 4, 41, 0.35));
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .im-logo:hover .im-logo__badge {
    transform: rotate(-6deg) scale(1.06);
  }

  .im-logo__word {
    font-family: var(--font-heading--family, sans-serif);
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: 0.02em;
    line-height: 1.05;
    color: var(--color-foreground);
    display: flex;
    flex-direction: column;
    white-space: nowrap;
  }

  .im-logo__word b {
    color: #d90429;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 480px) {
    .im-logo__badge { width: 34px; height: 34px; }
    .im-logo__word { font-size: 0.9rem; }
    .im-logo__word b { font-size: 0.62rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.logo",
  "tag": null,
  "class": "header-logo",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.edit_logo_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_logo_on_home_page",
      "label": "t:settings.hide_logo_on_home_page",
      "info": "t:info.hide_logo_on_home_page_help"
    },
    {
      "type": "header",
      "content": "t:content.padding_desktop"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
