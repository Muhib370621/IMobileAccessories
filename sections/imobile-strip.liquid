{%- comment -%} iMobile Accessories — Image strip (horizontal gallery under hero) {%- endcomment -%}
<style>
  #imst-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: var(--color-background); }
  #imst-{{ section.id }} .imst__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imst-{{ section.id }} .imst__grid { display:grid; grid-template-columns: repeat({{ section.blocks.size | at_least: 1 }}, 1fr); gap:14px; }
  #imst-{{ section.id }} .imst__cell { position:relative; aspect-ratio: 4/5; border-radius:14px; overflow:hidden; background:#e9ebef; display:block; text-decoration:none; }
  #imst-{{ section.id }} .imst__cell img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition: transform .6s cubic-bezier(0.22,1,0.36,1); }
  #imst-{{ section.id }} .imst__cell:hover img { transform: scale(1.06); }
  #imst-{{ section.id }} .imst__ph { position:absolute; inset:0; display:grid; place-items:center; background:linear-gradient(135deg,#eef0f4,#dfe3ea); color:#b3bcca; }
  #imst-{{ section.id }} .imst__ph svg { width:34%; max-width:46px; }
  #imst-{{ section.id }} .imst__cap { position:absolute; left:0; right:0; bottom:0; z-index:2; padding:12px; color:#fff; font-family: var(--font-accent--family, sans-serif); font-weight:600; font-size:0.82rem; background:linear-gradient(180deg, transparent, rgba(20,22,26,0.7)); }
  @media (max-width:749px){ #imst-{{ section.id }} .imst__grid{ grid-auto-flow:column; grid-auto-columns:44%; grid-template-columns:none; overflow-x:auto; scroll-snap-type:x mandatory; } #imst-{{ section.id }} .imst__cell{ scroll-snap-align:start; } }
</style>
<section id="imst-{{ section.id }}">
  <div class="imst__inner">
    <div class="imst__grid">
      {%- for block in section.blocks -%}
        <a class="imst__cell" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.caption | escape }}" loading="lazy">
          {%- else -%}
            <span class="imst__ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="7" y="2" width="10" height="20" rx="2.5"/></svg></span>
          {%- endif -%}
          {%- if block.settings.caption != blank -%}<span class="imst__cap">{{ block.settings.caption }}</span>{%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Image Strip",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 }
  ],
  "blocks": [
    {
      "type": "cell",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "iMobile — Image Strip",
      "blocks": [
        { "type": "cell", "settings": { "caption": "Phones" } },
        { "type": "cell", "settings": { "caption": "Earbuds" } },
        { "type": "cell", "settings": { "caption": "Watches" } },
        { "type": "cell", "settings": { "caption": "Chargers" } },
        { "type": "cell", "settings": { "caption": "Covers" } }
      ]
    }
  ]
}
{% endschema %}
