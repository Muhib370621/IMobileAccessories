{%- comment -%} Home hero {%- endcomment -%}
<section class="section hero reveal">
  <div class="container hero__grid">
    <div>
      {%- if section.settings.show_rating -%}
        <span class="hero__rating"><span class="hero__stars">★★★★★</span> {{ section.settings.rating_text }}</span>
      {%- endif -%}
      <h1>{{ section.settings.heading }} {%- if section.settings.rotating_words != blank %} <span class="hero__rot" data-rotate="{{ section.settings.rotating_words | escape }}">{{ section.settings.rotating_words | split: ',' | first | strip }}</span>{% endif %}</h1>
      {%- if section.settings.text != blank -%}<p class="hero__lead">{{ section.settings.text }}</p>{%- endif -%}
      <div class="hero__cta">
        {%- if section.settings.btn1_label != blank -%}<a class="btn btn--primary" href="{{ section.settings.btn1_link | default: routes.all_products_collection_url }}">{{ section.settings.btn1_label }}</a>{%- endif -%}
        {%- if section.settings.btn2_label != blank -%}<a class="btn btn--outline" href="{{ section.settings.btn2_link | default: routes.all_products_collection_url }}">{{ section.settings.btn2_label }}</a>{%- endif -%}
        {%- if section.settings.show_wa -%}<a class="btn btn--wa" href="https://wa.me/{{ settings.whatsapp_1_intl }}" target="_blank" rel="noopener">{% render 'icon', name: 'whatsapp', size: 18 %} WhatsApp</a>{%- endif -%}
      </div>
      {%- if section.settings.show_stats -%}
        <div class="hero__stats">
          <div class="hero__stat"><b>100%</b><span>Original Products</span></div>
          <div class="hero__stat"><b>10+</b><span>Categories</span></div>
          <div class="hero__stat"><b>Fast</b><span>City Delivery</span></div>
        </div>
      {%- endif -%}
    </div>
    <div class="hero__media">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1100 }}" alt="{{ section.settings.heading | escape }}" width="1100" loading="eager">
      {%- else -%}
        <div class="hero__ph">{% render 'icon', name: 'phone', size: 120 %}</div>
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": true },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "Trusted by customers across Karachi" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Smart Mobiles & Accessories for" },
    { "type": "text", "id": "rotating_words", "label": "Rotating words (comma separated)", "default": "Work, Travel, Gaming, Life" },
    { "type": "text", "id": "text", "label": "Text", "default": "We deal in all mobile phones and accessories — genuine products, best prices, and fast delivery across Karachi." },
    { "type": "text", "id": "btn1_label", "label": "Button 1 label", "default": "Shop All" },
    { "type": "url", "id": "btn1_link", "label": "Button 1 link" },
    { "type": "text", "id": "btn2_label", "label": "Button 2 label", "default": "See More" },
    { "type": "url", "id": "btn2_link", "label": "Button 2 link" },
    { "type": "checkbox", "id": "show_wa", "label": "Show WhatsApp button", "default": true },
    { "type": "checkbox", "id": "show_stats", "label": "Show stats", "default": true },
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
