{%- comment -%} iMobile Accessories — Promo / deal banner {%- endcomment -%}
<style>
  #impromo-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: var(--color-background); }
  #impromo-{{ section.id }} .impromo__inner {
    max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px;
  }
  #impromo-{{ section.id }} .impromo__band {
    position:relative; overflow:hidden; border-radius:24px; padding: 48px 44px;
    background: linear-gradient(120deg, #d90429 0%, #0d0d0f 70%);
    color:#fff; display:flex; align-items:center; justify-content:space-between; gap:28px; flex-wrap:wrap;
  }
  #impromo-{{ section.id }} .impromo__band::after {
    content:""; position:absolute; right:-60px; top:-60px; width:280px; height:280px; border-radius:50%;
    background: radial-gradient(circle, rgba(255,255,255,0.14), transparent 70%);
  }
  #impromo-{{ section.id }} .impromo__badge {
    display:inline-block; background:#e11d48; color:#fff; font-family: var(--font-accent--family, sans-serif);
    font-weight:700; font-size:0.78rem; letter-spacing:0.04em; padding:6px 14px; border-radius:999px; margin-bottom:14px;
  }
  #impromo-{{ section.id }} .impromo__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.6rem,4vw,2.6rem); margin:0 0 8px; line-height:1.1; position:relative; }
  #impromo-{{ section.id }} .impromo__text { margin:0; opacity:0.85; font-size:1rem; max-width:52ch; position:relative; }
  #impromo-{{ section.id }} .impromo__btn {
    position:relative; display:inline-flex; align-items:center; gap:10px; white-space:nowrap;
    background:#fff; color:#0d0d0f; text-decoration:none; font-family: var(--font-accent--family, sans-serif);
    text-transform:uppercase; font-weight:600; font-size:0.85rem; padding:15px 28px; border-radius:10px;
    transition: transform .25s cubic-bezier(0.22,1,0.36,1), box-shadow .25s;
  }
  #impromo-{{ section.id }} .impromo__btn:hover { transform: translateY(-3px); box-shadow:0 16px 30px -12px rgba(0,0,0,0.5); }
  @media (max-width:700px){ #impromo-{{ section.id }} .impromo__band{ padding:34px 26px; } }
</style>
<section id="impromo-{{ section.id }}">
  <div class="impromo__inner">
    <div class="impromo__band">
      <div>
        {%- if section.settings.badge != blank -%}<span class="impromo__badge">{{ section.settings.badge }}</span>{%- endif -%}
        <h2 class="impromo__title">{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}<p class="impromo__text">{{ section.settings.text }}</p>{%- endif -%}
      </div>
      {%- if section.settings.btn_label != blank -%}
        <a class="impromo__btn" href="{{ section.settings.btn_link | default: '#' }}">{{ section.settings.btn_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Promo Banner",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Limited Time" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Deals on Genuine Mobiles & Accessories" },
    { "type": "text", "id": "text", "label": "Text", "default": "Grab original earbuds, chargers, covers and more at unbeatable prices — while stock lasts." },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop Deals" },
    { "type": "url", "id": "btn_link", "label": "Button link" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 20 }
  ],
  "presets": [{ "name": "iMobile — Promo Banner" }]
}
{% endschema %}
