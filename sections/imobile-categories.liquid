{%- comment -%}
  iMobile Accessories — Shop by Category
  Each tile links to a matching collection (by handle) if it exists,
  otherwise falls back to a search for that term, so links never 404.
{%- endcomment -%}

{%- liquid
  assign cats = section.settings.categories | newline_to_br | split: '<br />'
-%}

<style>
  #imcat-{{ section.id }} {
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    background: var(--color-background);
    color: var(--color-foreground);
  }
  #imcat-{{ section.id }} .imcat__inner {
    max-width: var(--page-width, 1400px);
    margin-inline: auto;
    padding-inline: 20px;
  }
  #imcat-{{ section.id }} .imcat__head {
    text-align: center;
    margin-bottom: 40px;
  }
  #imcat-{{ section.id }} .imcat__eyebrow {
    display: inline-block;
    font-family: var(--font-accent--family, sans-serif);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
    font-weight: 600;
    color: #d90429;
    margin-bottom: 10px;
  }
  #imcat-{{ section.id }} .imcat__title {
    font-family: var(--font-heading--family, sans-serif);
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    line-height: 1.1;
    margin: 0;
    color: var(--color-foreground-heading, var(--color-foreground));
  }
  #imcat-{{ section.id }} .imcat__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 18px;
  }
  #imcat-{{ section.id }} .imcat__card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    text-align: center;
    text-decoration: none;
    padding: 26px 14px;
    border-radius: 18px;
    background: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
    border: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
    color: var(--color-foreground);
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s cubic-bezier(0.22,1,0.36,1), border-color 0.4s;
    overflow: hidden;
  }
  #imcat-{{ section.id }} .imcat__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(217,4,41,0.10), rgba(11,30,61,0.04));
    opacity: 0;
    transition: opacity 0.4s;
  }
  #imcat-{{ section.id }} .imcat__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px -20px rgba(11,30,61,0.45);
    border-color: rgba(217,4,41,0.4);
  }
  #imcat-{{ section.id }} .imcat__card:hover::before { opacity: 1; }
  #imcat-{{ section.id }} .imcat__icon {
    position: relative;
    width: 62px;
    height: 62px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg, #d90429, #0d0d0f);
    color: #fff;
    box-shadow: 0 10px 22px -10px rgba(217,4,41,0.7);
    transition: transform 0.45s cubic-bezier(0.22,1,0.36,1);
  }
  #imcat-{{ section.id }} .imcat__card:hover .imcat__icon { transform: scale(1.1) rotate(-4deg); }
  #imcat-{{ section.id }} .imcat__icon svg { width: 30px; height: 30px; }
  #imcat-{{ section.id }} .imcat__name {
    position: relative;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.25;
  }
  @media (max-width: 990px) {
    #imcat-{{ section.id }} .imcat__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    #imcat-{{ section.id }} .imcat__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    #imcat-{{ section.id }} .imcat__card { padding: 20px 10px; border-radius: 14px; }
    #imcat-{{ section.id }} .imcat__icon { width: 54px; height: 54px; }
  }
</style>

<section id="imcat-{{ section.id }}" class="imcat">
  <div class="imcat__inner">
    <div class="imcat__head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="imcat__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="imcat__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    <div class="imcat__grid">
      {%- for raw in cats -%}
        {%- liquid
          assign line = raw | strip
          if line == blank
            continue
          endif
          assign parts = line | split: '|'
          assign name = parts[0] | strip
          assign handle = parts[1] | strip
          assign icon = parts[2] | strip | default: 'accessory'
          assign coll = collections[handle]
          if coll != empty
            assign url = coll.url
          else
            assign q = name | url_encode
            assign url = routes.search_url | append: '?q=' | append: q
          endif
        -%}
        <a class="imcat__card" href="{{ url }}" aria-label="{{ name }}">
          <span class="imcat__icon">{% render 'im-cat-icon', name: icon %}</span>
          <span class="imcat__name">{{ name }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by Category",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse Our Range" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Category" },
    {
      "type": "textarea",
      "id": "categories",
      "label": "Categories (one per line: Name | collection-handle | icon)",
      "info": "icon options: phone, cover, charger, powerbank, earbuds, watch, headphones, screen, cable, accessory",
      "default": "Mobile Phones | mobile-phones | phone\nMobile Covers | mobile-covers | cover\nChargers | chargers | charger\nPower Banks | power-banks | powerbank\nEarbuds / AirPods | earbuds | earbuds\nSmart Watches | smart-watches | watch\nHeadphones | headphones | headphones\nScreen Protectors | screen-protectors | screen\nData Cables | data-cables | cable\nMobile Accessories | mobile-accessories | accessory"
    },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [{ "name": "iMobile — Shop by Category" }]
}
{% endschema %}
