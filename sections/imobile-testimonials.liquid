{%- comment -%} iMobile Accessories — Customer testimonials {%- endcomment -%}
<style>
  #imtes-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background:#f5f7fb; }
  #imtes-{{ section.id }} .imtes__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imtes-{{ section.id }} .imtes__head { text-align:center; margin-bottom:34px; }
  #imtes-{{ section.id }} .imtes__eyebrow { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.74rem; font-weight:700; color:#d90429; display:block; margin-bottom:8px; }
  #imtes-{{ section.id }} .imtes__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.6rem,3.5vw,2.3rem); margin:0; color:#0d0d0f; }
  #imtes-{{ section.id }} .imtes__grid { display:grid; grid-template-columns: repeat(3,1fr); gap:20px; }
  #imtes-{{ section.id }} .imtes__card { background:#fff; border:1px solid #eceff5; border-radius:18px; padding:26px; display:flex; flex-direction:column; gap:14px; transition: transform .4s cubic-bezier(0.22,1,0.36,1), box-shadow .4s; }
  #imtes-{{ section.id }} .imtes__card:hover { transform: translateY(-5px); box-shadow: 0 22px 40px -24px rgba(11,30,61,0.35); }
  #imtes-{{ section.id }} .imtes__stars { color:#f5a623; letter-spacing:2px; font-size:1rem; }
  #imtes-{{ section.id }} .imtes__quote { color:#47536b; line-height:1.6; margin:0; font-size:0.98rem; }
  #imtes-{{ section.id }} .imtes__who { display:flex; align-items:center; gap:12px; margin-top:auto; }
  #imtes-{{ section.id }} .imtes__ava { width:44px; height:44px; border-radius:50%; background:linear-gradient(135deg,#d90429,#0d0d0f); color:#fff; display:grid; place-items:center; font-family: var(--font-heading--family, sans-serif); font-weight:700; }
  #imtes-{{ section.id }} .imtes__name { font-weight:700; color:#0d0d0f; font-size:0.92rem; }
  #imtes-{{ section.id }} .imtes__role { font-size:0.78rem; color:#8a94a6; }
  @media (max-width:900px){ #imtes-{{ section.id }} .imtes__grid{ grid-template-columns:1fr; } }
</style>
<section id="imtes-{{ section.id }}">
  <div class="imtes__inner">
    <div class="imtes__head">
      {%- if section.settings.eyebrow != blank -%}<span class="imtes__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="imtes__title">{{ section.settings.heading }}</h2>
    </div>
    <div class="imtes__grid">
      {%- for block in section.blocks -%}
        <div class="imtes__card" {{ block.shopify_attributes }}>
          <div class="imtes__stars">★★★★★</div>
          <p class="imtes__quote">“{{ block.settings.quote }}”</p>
          <div class="imtes__who">
            <span class="imtes__ava">{{ block.settings.name | slice: 0 | upcase }}</span>
            <span>
              <span class="imtes__name">{{ block.settings.name }}</span><br>
              <span class="imtes__role">{{ block.settings.role }}</span>
            </span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Customers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Original product mila, price bhi best tha aur delivery bohat fast thi. Highly recommended!" },
        { "type": "text", "id": "name", "label": "Name", "default": "Ahmed Khan" },
        { "type": "text", "id": "role", "label": "Role", "default": "Verified Customer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "iMobile — Testimonials",
      "blocks": [
        { "type": "review", "settings": { "quote": "Original product mila, price bhi best tha aur delivery bohat fast thi. Highly recommended!", "name": "Ahmed Khan", "role": "Verified Customer" } },
        { "type": "review", "settings": { "quote": "Great collection of accessories and very honest dealing. WhatsApp par turant reply mila.", "name": "Sana Malik", "role": "Verified Customer" } },
        { "type": "review", "settings": { "quote": "Genuine mobile phone at a fair price. Shop staff bohat cooperative the. Will buy again.", "name": "Bilal Raza", "role": "Verified Customer" } }
      ]
    }
  ]
}
{% endschema %}
