{%- comment -%} Header {%- endcomment -%}
{%- if section.settings.show_announcement and section.settings.announcement != blank -%}
  <div class="announcement">{{ section.settings.announcement }} {% if settings.whatsapp_1 != blank %}&nbsp;·&nbsp; <a href="https://wa.me/{{ settings.whatsapp_1_intl }}">WhatsApp {{ settings.whatsapp_1 }}</a>{% endif %}</div>
{%- endif -%}

<header class="header">
  <div class="container header__bar">
    <button class="header__icon header__menu-btn" data-nav-open aria-label="{{ 'general.menu' | t }}">{% render 'icon', name: 'menu', size: 24 %}</button>

    <nav class="header__nav" aria-label="Primary">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <a class="header__logo" href="{{ routes.root_url }}">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 400 }}" alt="{{ settings.brand_name | escape }}" style="width:{{ settings.logo_width }}px;height:auto">
      {%- else -%}
        {{ settings.brand_name }}
      {%- endif -%}
    </a>

    <div class="header__actions">
      <a class="header__icon" href="{{ routes.search_url }}" aria-label="{{ 'general.search' | t }}">{% render 'icon', name: 'search', size: 22 %}</a>
      <button class="header__icon" data-cart-open aria-label="{{ 'general.cart' | t }}">
        {% render 'icon', name: 'cart', size: 22 %}
        <span class="cart-count{% if cart.item_count == 0 %} hidden{% endif %}" data-cart-count>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

<nav class="mobile-nav" id="mobileNav" aria-label="Mobile">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
    <strong>{{ 'general.menu' | t }}</strong>
    <button class="header__icon" data-nav-close aria-label="{{ 'general.close' | t }}">{% render 'icon', name: 'close', size: 22 %}</button>
  </div>
  {%- for link in section.settings.menu.links -%}
    <a href="{{ link.url }}" data-nav-close>{{ link.title }}</a>
  {%- endfor -%}
  {%- if settings.whatsapp_1 != blank -%}
    <a class="btn btn--wa btn--block" style="margin-top:18px" href="https://wa.me/{{ settings.whatsapp_1_intl }}">{% render 'icon', name: 'whatsapp', size: 18 %} WhatsApp Us</a>
  {%- endif -%}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement", "label": "Announcement text", "default": "We deal in all mobile phones and accessories" }
  ]
}
{% endschema %}
