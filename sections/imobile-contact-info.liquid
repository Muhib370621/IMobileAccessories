{%- comment -%} iMobile Accessories — Contact info + map + WhatsApp {%- endcomment -%}
{%- assign wa_msg = 'Assalam-o-Alaikum! Mujhe iMobile Accessories se maloomat chahiye.' | url_encode -%}
{%- assign map_q = section.settings.map_query | default: 'Amma Tower, M.A. Jinnah Road, Karachi' | url_encode -%}
<style>
  #imcontact-{{ section.id }} {
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    background: var(--color-background);
    color: var(--color-foreground);
  }
  #imcontact-{{ section.id }} .imc__inner {
    max-width: var(--page-width, 1400px);
    margin-inline: auto; padding-inline: 20px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: stretch;
  }
  #imcontact-{{ section.id }} .imc__card {
    background: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
    border: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
    border-radius: 18px; padding: 30px;
  }
  #imcontact-{{ section.id }} h2 { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.4rem,3vw,2rem); margin: 0 0 6px; }
  #imcontact-{{ section.id }} .imc__lead { opacity: 0.75; margin: 0 0 24px; }
  #imcontact-{{ section.id }} .imc__row { display: flex; gap: 14px; align-items: flex-start; padding: 14px 0; border-top: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent); }
  #imcontact-{{ section.id }} .imc__row:first-of-type { border-top: none; }
  #imcontact-{{ section.id }} .imc__ic { flex: 0 0 42px; width: 42px; height: 42px; border-radius: 12px; display: grid; place-items: center; background: linear-gradient(135deg,#d90429,#0d0d0f); color: #fff; }
  #imcontact-{{ section.id }} .imc__ic svg { width: 22px; height: 22px; }
  #imcontact-{{ section.id }} .imc__label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.6; margin: 0 0 3px; }
  #imcontact-{{ section.id }} .imc__val { font-weight: 600; margin: 0; line-height: 1.4; }
  #imcontact-{{ section.id }} .imc__wa { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 22px; }
  #imcontact-{{ section.id }} .imc__wabtn {
    display: inline-flex; align-items: center; gap: 10px; text-decoration: none;
    background: #25D366; color: #fff; font-weight: 600; font-size: 0.92rem;
    padding: 12px 20px; border-radius: 999px; transition: transform 0.25s cubic-bezier(0.22,1,0.36,1), box-shadow 0.25s;
    box-shadow: 0 10px 24px -10px rgba(37,211,102,0.7);
  }
  #imcontact-{{ section.id }} .imc__wabtn:hover { transform: translateY(-3px); box-shadow: 0 16px 30px -10px rgba(37,211,102,0.8); }
  #imcontact-{{ section.id }} .imc__wabtn svg { width: 20px; height: 20px; }
  #imcontact-{{ section.id }} .imc__map { border-radius: 18px; overflow: hidden; min-height: 340px; border: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent); }
  #imcontact-{{ section.id }} .imc__map iframe { width: 100%; height: 100%; min-height: 340px; border: 0; display: block; filter: saturate(1.05); }
  @media (max-width: 850px) {
    #imcontact-{{ section.id }} .imc__inner { grid-template-columns: 1fr; }
  }
</style>
<section id="imcontact-{{ section.id }}">
  <div class="imc__inner">
    <div class="imc__card">
      <h2>{{ section.settings.heading }}</h2>
      <p class="imc__lead">{{ section.settings.subheading }}</p>

      <div class="imc__row">
        <span class="imc__ic"><svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
        <div><p class="imc__label">Visit Our Shop</p><p class="imc__val">{{ section.settings.address }}</p></div>
      </div>

      <div class="imc__row">
        <span class="imc__ic">{% render 'im-wa-icon', size: 22 %}</span>
        <div>
          <p class="imc__label">WhatsApp / Call</p>
          <p class="imc__val">{{ section.settings.phone1 }}<br>{{ section.settings.phone2 }}</p>
        </div>
      </div>

      <div class="imc__row">
        <span class="imc__ic"><svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
        <div><p class="imc__label">Store Timings</p><p class="imc__val">{{ section.settings.timings }}</p></div>
      </div>

      <div class="imc__wa">
        <a class="imc__wabtn" href="https://wa.me/923152972723?text={{ wa_msg }}" target="_blank" rel="noopener">{% render 'im-wa-icon', size: 20 %} {{ section.settings.phone1 }}</a>
        <a class="imc__wabtn" href="https://wa.me/923482532992?text={{ wa_msg }}" target="_blank" rel="noopener">{% render 'im-wa-icon', size: 20 %} {{ section.settings.phone2 }}</a>
      </div>
    </div>

    <div class="imc__map">
      <iframe
        src="https://maps.google.com/maps?q={{ map_q }}&z=16&output=embed"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="iMobile Accessories store location"></iframe>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Contact Info",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in Touch" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "We deal in all mobile phones and accessories. Visit our shop or message us on WhatsApp." },
    { "type": "text", "id": "address", "label": "Address", "default": "Shop No. G-93, Amma Tower, M.A. Jinnah Road, Karachi." },
    { "type": "text", "id": "phone1", "label": "WhatsApp number 1", "default": "0315-2972723" },
    { "type": "text", "id": "phone2", "label": "WhatsApp number 2", "default": "0348-2532992" },
    { "type": "text", "id": "timings", "label": "Store timings", "default": "Monday – Sunday: 11:00 AM – 10:00 PM" },
    { "type": "text", "id": "map_query", "label": "Google Maps search query", "default": "Amma Tower, M.A. Jinnah Road, Karachi" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 }
  ],
  "presets": [{ "name": "iMobile — Contact Info" }]
}
{% endschema %}
