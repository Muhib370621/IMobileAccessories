{%- comment -%} iMobile Accessories — FAQ accordion {%- endcomment -%}
<style>
  #imfaq-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: {{ section.settings.background }}; }
  #imfaq-{{ section.id }} .imfaq__inner { max-width: 860px; margin-inline:auto; padding-inline:20px; }
  #imfaq-{{ section.id }} .imfaq__head { text-align:center; margin-bottom:34px; }
  #imfaq-{{ section.id }} .imfaq__eyebrow { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.72rem; font-weight:700; color:#8a94a6; display:block; margin-bottom:8px; }
  #imfaq-{{ section.id }} .imfaq__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.5rem,3.5vw,2.3rem); margin:0 0 6px; color:#222325; }
  #imfaq-{{ section.id }} .imfaq__sub { margin:0; color:#7a828f; }
  #imfaq-{{ section.id }} details { border:1px solid #e7e9ee; border-radius:12px; background:#fff; margin-bottom:12px; overflow:hidden; }
  #imfaq-{{ section.id }} summary { list-style:none; cursor:pointer; padding:18px 20px; display:flex; align-items:center; justify-content:space-between; gap:16px; font-family: var(--font-heading--family, sans-serif); font-weight:600; font-size:1rem; color:#222325; }
  #imfaq-{{ section.id }} summary::-webkit-details-marker { display:none; }
  #imfaq-{{ section.id }} .imfaq__plus { flex:0 0 auto; width:22px; height:22px; position:relative; transition: transform .3s ease; }
  #imfaq-{{ section.id }} .imfaq__plus::before, #imfaq-{{ section.id }} .imfaq__plus::after { content:""; position:absolute; background:#2d3645; border-radius:2px; }
  #imfaq-{{ section.id }} .imfaq__plus::before { top:10px; left:2px; right:2px; height:2px; }
  #imfaq-{{ section.id }} .imfaq__plus::after { left:10px; top:2px; bottom:2px; width:2px; transition: transform .3s ease; }
  #imfaq-{{ section.id }} details[open] .imfaq__plus::after { transform: rotate(90deg); opacity:0; }
  #imfaq-{{ section.id }} .imfaq__ans { padding:0 20px 20px; color:#5f6773; line-height:1.6; font-size:0.95rem; }
</style>
<section id="imfaq-{{ section.id }}">
  <div class="imfaq__inner">
    <div class="imfaq__head">
      {%- if section.settings.eyebrow != blank -%}<span class="imfaq__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="imfaq__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p class="imfaq__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
    {%- for block in section.blocks -%}
      <details {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
        <summary>{{ block.settings.question }}<span class="imfaq__plus"></span></summary>
        <div class="imfaq__ans">{{ block.settings.answer }}</div>
      </details>
    {%- endfor -%}
  </div>
</section>
{% schema %}
{
  "name": "iMobile FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions & Answers" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Everything you need to know before you shop with us." },
    { "type": "color", "id": "background", "label": "Background", "default": "#f6f7f9" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Q&A",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Do you sell original products?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Yes — we deal only in 100% genuine, branded mobile phones and accessories." }
      ]
    }
  ],
  "presets": [
    {
      "name": "iMobile — FAQ",
      "blocks": [
        { "type": "qa", "settings": { "question": "Do you sell original products?", "answer": "Yes — we deal only in 100% genuine, branded mobile phones and accessories." } },
        { "type": "qa", "settings": { "question": "Do you offer delivery across Pakistan?", "answer": "Yes, we deliver across Karachi and all of Pakistan. Message us on WhatsApp for delivery details." } },
        { "type": "qa", "settings": { "question": "How can I place an order?", "answer": "Order online through the website, or contact us directly on WhatsApp at 0315-2972723 / 0348-2532992." } },
        { "type": "qa", "settings": { "question": "Do accessories come with warranty?", "answer": "Branded products carry manufacturer warranty where applicable. Ask us about a specific product." } }
      ]
    }
  ]
}
{% endschema %}
