{%- comment -%} iMobile Accessories — Feature grid (image cards) {%- endcomment -%}
<style>
  #imfg-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: var(--color-background); }
  #imfg-{{ section.id }} .imfg__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imfg-{{ section.id }} .imfg__head { text-align:center; margin-bottom: 34px; }
  #imfg-{{ section.id }} .imfg__eyebrow { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.72rem; font-weight:700; color:#8a94a6; display:block; margin-bottom:8px; }
  #imfg-{{ section.id }} .imfg__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.5rem,3.5vw,2.3rem); margin:0; color:#0d0d0f; }
  #imfg-{{ section.id }} .imfg__grid { display:grid; grid-template-columns: repeat({{ section.settings.columns }}, 1fr); gap:18px; }
  #imfg-{{ section.id }} .imfg__card { position:relative; border-radius:16px; overflow:hidden; min-height:300px; display:flex; align-items:flex-end; text-decoration:none; background:#eef0f4; }
  #imfg-{{ section.id }} .imfg__card img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition: transform .6s cubic-bezier(0.22,1,0.36,1); }
  #imfg-{{ section.id }} .imfg__card:hover img { transform: scale(1.06); }
  #imfg-{{ section.id }} .imfg__ph { position:absolute; inset:0; display:grid; place-items:center; background:linear-gradient(135deg,#d90429,#0d0d0f); color:rgba(255,255,255,0.45); }
  #imfg-{{ section.id }} .imfg__ph svg { width:34%; }
  #imfg-{{ section.id }} .imfg__ov { position:absolute; inset:0; background:linear-gradient(180deg, rgba(20,22,26,0) 40%, rgba(20,22,26,0.82) 100%); z-index:1; }
  #imfg-{{ section.id }} .imfg__body { position:relative; z-index:2; padding:22px; color:#fff; }
  #imfg-{{ section.id }} .imfg__name { font-family: var(--font-heading--family, sans-serif); font-size:1.15rem; margin:0 0 12px; line-height:1.25; }
  #imfg-{{ section.id }} .imfg__link { display:inline-flex; align-items:center; gap:7px; font-family: var(--font-accent--family, sans-serif); font-size:0.85rem; font-weight:600; color:#fff; }
  #imfg-{{ section.id }} .imfg__card:hover .imfg__link { gap:11px; }
  #imfg-{{ section.id }} .imfg__link { transition: gap .25s ease; }
  @media (max-width: 990px) { #imfg-{{ section.id }} .imfg__grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 560px) { #imfg-{{ section.id }} .imfg__grid { grid-template-columns: 1fr; } #imfg-{{ section.id }} .imfg__card{ min-height:240px; } }
</style>
<section id="imfg-{{ section.id }}">
  <div class="imfg__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="imfg__head">
        {%- if section.settings.eyebrow != blank -%}<span class="imfg__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="imfg__title">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
    {%- endif -%}
    <div class="imfg__grid">
      {%- for block in section.blocks -%}
        <a class="imfg__card" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
          {%- else -%}
            <span class="imfg__ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="7" y="2" width="10" height="20" rx="2.5"/></svg></span>
          {%- endif -%}
          <span class="imfg__ov"></span>
          <span class="imfg__body">
            <span class="imfg__name">{{ block.settings.title }}</span>
            <span class="imfg__link">{{ block.settings.link_label | default: 'Shop Now' }} →</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Feature Grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why iMobile" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Accessories for Every Need" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Protective Phone Cases" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "iMobile — Feature Grid",
      "blocks": [
        { "type": "card", "settings": { "title": "Durable Phone Covers", "link_label": "Shop Now" } },
        { "type": "card", "settings": { "title": "Fast Chargers & Cables", "link_label": "Shop Now" } },
        { "type": "card", "settings": { "title": "Wireless Earbuds & Audio", "link_label": "Shop Now" } },
        { "type": "card", "settings": { "title": "Smart Watches & Straps", "link_label": "Shop Now" } }
      ]
    }
  ]
}
{% endschema %}
