{%- comment -%} Blog listing {%- endcomment -%}
{%- paginate blog.articles by 9 -%}
<section class="section">
  <div class="container">
    <div class="collection-hero reveal"><span class="eyebrow">Newsroom</span><h1 class="mt-0">{{ blog.title }}</h1></div>
    <div class="grid grid--3 stagger">
      {%- for article in blog.articles -%}
        <a class="card" href="{{ article.url }}">
          <span class="card__media">
            {%- if article.image -%}<img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" loading="lazy">
            {%- else -%}<span class="ph">{% render 'icon', name: 'star', size: 46 %}</span>{%- endif -%}
          </span>
          <span class="card__body">
            <span style="font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;color:#8a94a6;font-weight:600">{{ article.published_at | date: '%d %b %Y' }}</span>
            <span class="card__title">{{ article.title }}</span>
            <span style="color:#6a7280;font-size:.9rem">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</span>
          </span>
        </a>
      {%- else -%}
        <p class="empty">No posts yet.</p>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}
      <div style="display:flex;justify-content:center;gap:8px;margin-top:40px">
        {%- if paginate.previous -%}<a class="btn btn--outline" href="{{ paginate.previous.url }}">← Prev</a>{%- endif -%}
        {%- if paginate.next -%}<a class="btn btn--outline" href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}
{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
