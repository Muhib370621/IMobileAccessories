{%- comment -%} iMobile Accessories — Scrolling marquee band {%- endcomment -%}
{%- assign words = section.settings.text | split: '•' -%}
<style>
  #immq-{{ section.id }} { background: {{ section.settings.background }}; padding-block: {{ section.settings.padding }}px; overflow:hidden; }
  #immq-{{ section.id }} .immq__track { display:flex; width:max-content; animation: immq-scroll {{ section.settings.speed }}s linear infinite; }
  #immq-{{ section.id }} .immq__track:hover { animation-play-state: paused; }
  #immq-{{ section.id }} .immq__item { display:inline-flex; align-items:center; gap:22px; padding-inline:22px; font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.1rem,2.4vw,1.7rem); font-weight:700; color:{{ section.settings.color }}; white-space:nowrap; }
  #immq-{{ section.id }} .immq__dot { width:8px; height:8px; border-radius:50%; background:{{ section.settings.color }}; opacity:.5; }
  @keyframes immq-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce){ #immq-{{ section.id }} .immq__track{ animation:none; } }
</style>
<section id="immq-{{ section.id }}">
  <div class="immq__track">
    {%- for i in (1..2) -%}
      {%- for w in words -%}
        {%- assign t = w | strip -%}
        {%- if t != blank -%}<span class="immq__item">{{ t }}<span class="immq__dot"></span></span>{%- endif -%}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>
{% schema %}
{
  "name": "iMobile Marquee",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "text", "label": "Text (separate items with •)", "default": "Original Products • Best Prices in Karachi • Fast Delivery • All Mobile Accessories • Genuine Warranty • iMobile Accessories" },
    { "type": "color", "id": "background", "label": "Background", "default": "#2d3645" },
    { "type": "color", "id": "color", "label": "Text color", "default": "#ffffff" },
    { "type": "range", "id": "speed", "label": "Scroll duration (s)", "min": 10, "max": 60, "step": 2, "default": 28 },
    { "type": "range", "id": "padding", "label": "Padding (top & bottom)", "min": 6, "max": 60, "step": 2, "unit": "px", "default": 20 }
  ],
  "presets": [{ "name": "iMobile — Marquee" }]
}
{% endschema %}
