{%- comment -%} Footer {%- endcomment -%}
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <h4>{{ settings.brand_name }}</h4>
        <p>{{ settings.tagline }}.</p>
        <p>{{ settings.address }}</p>
        <p>{{ settings.store_timings }}</p>
      </div>

      <div>
        <h4>{{ section.settings.col1_title }}</h4>
        {%- for link in section.settings.menu_1.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      </div>

      <div>
        <h4>{{ section.settings.col2_title }}</h4>
        {%- for link in section.settings.menu_2.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      </div>

      <div>
        <h4>Contact</h4>
        {%- if settings.whatsapp_1 != blank -%}<a href="https://wa.me/{{ settings.whatsapp_1_intl }}">{% render 'icon', name: 'whatsapp', size: 15 %} {{ settings.whatsapp_1 }}</a>{%- endif -%}
        {%- if settings.whatsapp_2 != blank -%}<a href="https://wa.me/{{ settings.whatsapp_2_intl }}">{% render 'icon', name: 'whatsapp', size: 15 %} {{ settings.whatsapp_2 }}</a>{%- endif -%}
        <div class="footer__social" style="margin-top:16px">
          {%- if section.settings.facebook != blank -%}<a href="{{ section.settings.facebook }}" aria-label="Facebook">{% render 'icon', name: 'facebook', size: 18 %}</a>{%- endif -%}
          {%- if section.settings.instagram != blank -%}<a href="{{ section.settings.instagram }}" aria-label="Instagram">{% render 'icon', name: 'instagram', size: 18 %}</a>{%- endif -%}
          {%- if section.settings.tiktok != blank -%}<a href="{{ section.settings.tiktok }}" aria-label="TikTok">{% render 'icon', name: 'tiktok', size: 18 %}</a>{%- endif -%}
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ settings.brand_name }}. All rights reserved.</span>
      <span>{{ powered_by_link }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "col1_title", "label": "Column 1 title", "default": "Quick Links" },
    { "type": "link_list", "id": "menu_1", "label": "Column 1 menu", "default": "footer" },
    { "type": "text", "id": "col2_title", "label": "Column 2 title", "default": "Categories" },
    { "type": "link_list", "id": "menu_2", "label": "Column 2 menu" },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" }
  ]
}
{% endschema %}
