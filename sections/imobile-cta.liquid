{%- comment -%} iMobile Accessories — WhatsApp CTA band {%- endcomment -%}
{%- assign wa_msg = 'Assalam-o-Alaikum! Mujhe iMobile Accessories se maloomat chahiye.' | url_encode -%}
<style>
  #imcta-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: var(--color-background); }
  #imcta-{{ section.id }} .imcta__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imcta-{{ section.id }} .imcta__band {
    border-radius:24px; padding: 44px; text-align:center;
    background: linear-gradient(135deg, #128C4A 0%, #25D366 100%); color:#fff;
    position:relative; overflow:hidden;
  }
  #imcta-{{ section.id }} .imcta__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.5rem,3.5vw,2.3rem); margin:0 0 10px; }
  #imcta-{{ section.id }} .imcta__text { margin:0 auto 26px; opacity:0.92; max-width:56ch; }
  #imcta-{{ section.id }} .imcta__btns { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; }
  #imcta-{{ section.id }} .imcta__btn {
    display:inline-flex; align-items:center; gap:10px; background:#fff; color:#222325; text-decoration:none;
    font-family: var(--font-accent--family, sans-serif); font-weight:700; font-size:0.95rem;
    padding:14px 26px; border-radius:999px; transition: transform .25s cubic-bezier(0.22,1,0.36,1), box-shadow .25s;
  }
  #imcta-{{ section.id }} .imcta__btn:hover { transform: translateY(-3px); box-shadow:0 16px 30px -12px rgba(0,0,0,0.4); }
  #imcta-{{ section.id }} .imcta__btn svg path { fill:#128C4A; }
</style>
<section id="imcta-{{ section.id }}">
  <div class="imcta__inner">
    <div class="imcta__band">
      <h2 class="imcta__title">{{ section.settings.heading }}</h2>
      <p class="imcta__text">{{ section.settings.text }}</p>
      <div class="imcta__btns">
        <a class="imcta__btn" href="https://wa.me/923152972723?text={{ wa_msg }}" target="_blank" rel="noopener">{% render 'im-wa-icon', size: 20 %} 0315-2972723</a>
        <a class="imcta__btn" href="https://wa.me/923482532992?text={{ wa_msg }}" target="_blank" rel="noopener">{% render 'im-wa-icon', size: 20 %} 0348-2532992</a>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile WhatsApp CTA",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Have a Question? Chat With Us on WhatsApp" },
    { "type": "text", "id": "text", "label": "Text", "default": "We deal in all mobile phones and accessories. Message us for prices, availability, and quick order — we reply fast!" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [{ "name": "iMobile — WhatsApp CTA" }]
}
{% endschema %}
