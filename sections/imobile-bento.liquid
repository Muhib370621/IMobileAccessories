{%- comment -%} iMobile Accessories — Bento collections grid (Smart-style) {%- endcomment -%}
{%- assign b = section.blocks -%}
<style>
  #imbn-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: var(--color-background); }
  #imbn-{{ section.id }} .imbn__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imbn-{{ section.id }} .imbn__head { margin-bottom: 26px; }
  #imbn-{{ section.id }} .imbn__eyebrow { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.72rem; font-weight:700; color:#8a94a6; display:block; margin-bottom:8px; }
  #imbn-{{ section.id }} .imbn__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.5rem,3.5vw,2.3rem); margin:0 0 6px; color:#0d0d0f; }
  #imbn-{{ section.id }} .imbn__sub { margin:0; color:#7a828f; }
  #imbn-{{ section.id }} .imbn__grid { display:grid; grid-template-columns: 1fr 1fr; gap:16px; }
  #imbn-{{ section.id }} .imbn__right { display:grid; grid-template-rows: 1.15fr 1fr; gap:16px; }
  #imbn-{{ section.id }} .imbn__rbottom { display:grid; grid-template-columns: 1fr 1fr; gap:16px; }
  #imbn-{{ section.id }} .imbn__card { position:relative; display:flex; align-items:flex-end; border-radius:16px; overflow:hidden; text-decoration:none; min-height:190px; background:#e9ebef; }
  #imbn-{{ section.id }} .imbn__card--big { min-height:400px; height:100%; }
  #imbn-{{ section.id }} .imbn__card img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition: transform .6s cubic-bezier(0.22,1,0.36,1); }
  #imbn-{{ section.id }} .imbn__card:hover img { transform: scale(1.06); }
  #imbn-{{ section.id }} .imbn__ph { position:absolute; inset:0; display:grid; place-items:center; background:linear-gradient(135deg,#3a4152,#0d0d0f); color:rgba(255,255,255,0.4); }
  #imbn-{{ section.id }} .imbn__ph svg { width:30%; max-width:70px; }
  #imbn-{{ section.id }} .imbn__ov { position:absolute; inset:0; background:linear-gradient(180deg, rgba(20,22,26,0) 45%, rgba(20,22,26,0.78) 100%); z-index:1; }
  #imbn-{{ section.id }} .imbn__body { position:relative; z-index:2; padding:22px; color:#fff; }
  #imbn-{{ section.id }} .imbn__name { font-family: var(--font-heading--family, sans-serif); font-size:1.2rem; margin:0 0 10px; }
  #imbn-{{ section.id }} .imbn__card--big .imbn__name { font-size:1.6rem; }
  #imbn-{{ section.id }} .imbn__link { display:inline-flex; align-items:center; gap:7px; font-family: var(--font-accent--family, sans-serif); font-size:0.82rem; font-weight:600; color:#fff; background:rgba(255,255,255,0.16); backdrop-filter:blur(4px); padding:8px 16px; border-radius:6px; transition: background .25s; }
  #imbn-{{ section.id }} .imbn__card:hover .imbn__link { background:rgba(255,255,255,0.28); }
  @media (max-width: 749px) {
    #imbn-{{ section.id }} .imbn__grid { grid-template-columns: 1fr; }
    #imbn-{{ section.id }} .imbn__card--big { min-height:260px; }
  }
</style>
<section id="imbn-{{ section.id }}">
  <div class="imbn__inner">
    <div class="imbn__head">
      {%- if section.settings.eyebrow != blank -%}<span class="imbn__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="imbn__title">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.subheading != blank -%}<p class="imbn__sub">{{ section.settings.subheading }}</p>{%- endif -%}
    </div>
    <div class="imbn__grid">
      {%- if b[0] -%}
        {%- render 'im-bento-card', block: b[0], big: true, idx: 0 -%}
      {%- endif -%}
      <div class="imbn__right">
        {%- if b[1] -%}{%- render 'im-bento-card', block: b[1], big: false, idx: 1 -%}{%- endif -%}
        <div class="imbn__rbottom">
          {%- if b[2] -%}{%- render 'im-bento-card', block: b[2], big: false, idx: 2 -%}{%- endif -%}
          {%- if b[3] -%}{%- render 'im-bento-card', block: b[3], big: false, idx: 3 -%}{%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Bento Collections",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Mobiles & Accessories, Smarter Living" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Discover genuine accessories designed to enhance your devices and simplify everyday life." },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Mobile Covers" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "iMobile — Bento Collections",
      "blocks": [
        { "type": "tile", "settings": { "title": "Mobile Covers", "link_label": "Shop Now" } },
        { "type": "tile", "settings": { "title": "Smart Watches", "link_label": "Shop Now" } },
        { "type": "tile", "settings": { "title": "Earbuds", "link_label": "Shop Now" } },
        { "type": "tile", "settings": { "title": "Chargers", "link_label": "Shop Now" } }
      ]
    }
  ]
}
{% endschema %}
