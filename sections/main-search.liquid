{%- comment -%} Search page {%- endcomment -%}
<section class="section">
  <div class="container">
    <div class="collection-hero reveal">
      <span class="eyebrow">Search</span>
      <h1 class="mt-0">Search our store</h1>
      <form action="{{ routes.search_url }}" method="get" role="search" style="max-width:560px;margin:20px auto 0;display:flex;gap:10px">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products…" style="flex:1;padding:14px 16px;border:1px solid var(--muted);border-radius:var(--radius);font-size:1rem">
        <button type="submit" class="btn btn--primary">{{ 'general.search' | t }}</button>
      </form>
    </div>

    {%- if search.performed -%}
      {%- if search.results.size > 0 -%}
        <p style="text-align:center;color:#6a7280;margin-bottom:24px">{{ search.results_count }} results for &ldquo;{{ search.terms | escape }}&rdquo;</p>
        <div class="grid grid--4 stagger">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}{% render 'product-card', product: item %}{%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="empty">No results for &ldquo;{{ search.terms | escape }}&rdquo;. Try another search.</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
