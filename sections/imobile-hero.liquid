{%- comment -%} iMobile Accessories — Hero (Dynamic-style split hero) {%- endcomment -%}
<style>
  #imhero-{{ section.id }} {
    background:
      radial-gradient(1200px 500px at 85% -10%, rgba(45,72,149,0.12), transparent 60%),
      linear-gradient(180deg, #f5f7fb 0%, #ffffff 100%);
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }
  #imhero-{{ section.id }} .imh__inner {
    max-width: var(--page-width, 1400px);
    margin-inline: auto; padding-inline: 20px;
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 40px; align-items: center;
  }
  #imhero-{{ section.id }} .imh__eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-accent--family, sans-serif);
    text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.78rem; font-weight: 700;
    color: #2d4895; margin-bottom: 18px;
  }
  #imhero-{{ section.id }} .imh__eyebrow::before { content:""; width:28px; height:2px; background:#2d4895; display:inline-block; }
  #imhero-{{ section.id }} .imh__title {
    font-family: var(--font-heading--family, sans-serif);
    font-size: clamp(2.1rem, 5vw, 3.9rem); line-height: 1.05; letter-spacing: -0.02em;
    margin: 0 0 18px; color: #0b1e3d;
  }
  #imhero-{{ section.id }} .imh__title .accent { color: #2d4895; }
  #imhero-{{ section.id }} .imh__text { font-size: 1.05rem; line-height: 1.6; color: #47536b; margin: 0 0 30px; max-width: 46ch; }
  #imhero-{{ section.id }} .imh__cta { display: flex; flex-wrap: wrap; gap: 14px; }
  #imhero-{{ section.id }} .imh__btn {
    display: inline-flex; align-items: center; gap: 10px; text-decoration: none;
    font-family: var(--font-accent--family, sans-serif); text-transform: uppercase;
    font-size: 0.86rem; font-weight: 600; letter-spacing: 0.03em; padding: 15px 28px; border-radius: 10px;
    transition: transform 0.25s cubic-bezier(0.22,1,0.36,1), box-shadow 0.25s, background 0.25s;
  }
  #imhero-{{ section.id }} .imh__btn--primary { background: #2d4895; color: #fff; box-shadow: 0 14px 30px -12px rgba(45,72,149,0.7); }
  #imhero-{{ section.id }} .imh__btn--primary:hover { transform: translateY(-3px); background: #0b1e3d; }
  #imhero-{{ section.id }} .imh__btn--wa { background: #25D366; color: #fff; box-shadow: 0 14px 30px -12px rgba(37,211,102,0.7); }
  #imhero-{{ section.id }} .imh__btn--wa:hover { transform: translateY(-3px); }
  #imhero-{{ section.id }} .imh__btn--ghost { background: transparent; color: #0b1e3d; border: 1.5px solid #0b1e3d; }
  #imhero-{{ section.id }} .imh__btn--ghost:hover { transform: translateY(-3px); background: #0b1e3d; color: #fff; }
  #imhero-{{ section.id }} .imh__media { position: relative; }
  #imhero-{{ section.id }} .imh__media img { width: 100%; height: auto; display: block; border-radius: 22px; }
  #imhero-{{ section.id }} .imh__ph {
    aspect-ratio: 5/4; border-radius: 22px;
    background: linear-gradient(135deg, #2d4895, #0b1e3d);
    display: grid; place-items: center; color: #ffffff; box-shadow: 0 40px 80px -40px rgba(11,30,61,0.6);
  }
  #imhero-{{ section.id }} .imh__ph svg { width: 46%; height: auto; opacity: 0.9; }
  #imhero-{{ section.id }} .imh__stats { display: flex; gap: 26px; margin-top: 34px; flex-wrap: wrap; }
  #imhero-{{ section.id }} .imh__stat b { display:block; font-family: var(--font-heading--family, sans-serif); font-size: 1.5rem; color:#0b1e3d; line-height:1; }
  #imhero-{{ section.id }} .imh__stat span { font-size: 0.8rem; color:#6b7688; }
  @media (max-width: 860px) {
    #imhero-{{ section.id }} .imh__inner { grid-template-columns: 1fr; gap: 30px; }
    #imhero-{{ section.id }} .imh__media { order: -1; }
  }
</style>
<section id="imhero-{{ section.id }}">
  <div class="imh__inner">
    <div class="imh__content">
      {%- if section.settings.eyebrow != blank -%}<span class="imh__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h1 class="imh__title">{{ section.settings.heading }}{% if section.settings.heading_accent != blank %} <span class="accent">{{ section.settings.heading_accent }}</span>{% endif %}</h1>
      {%- if section.settings.text != blank -%}<p class="imh__text">{{ section.settings.text }}</p>{%- endif -%}
      <div class="imh__cta">
        {%- if section.settings.btn1_label != blank -%}
          <a class="imh__btn imh__btn--primary" href="{{ section.settings.btn1_link | default: '#' }}">{{ section.settings.btn1_label }}</a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a class="imh__btn imh__btn--ghost" href="{{ section.settings.btn2_link | default: '#' }}">{{ section.settings.btn2_label }}</a>
        {%- endif -%}
        {%- if section.settings.show_whatsapp -%}
          <a class="imh__btn imh__btn--wa" href="https://wa.me/923152972723" target="_blank" rel="noopener">{% render 'im-wa-icon', size: 18 %} WhatsApp</a>
        {%- endif -%}
      </div>
      {%- if section.settings.show_stats -%}
        <div class="imh__stats">
          <div class="imh__stat"><b>100%</b><span>Original Products</span></div>
          <div class="imh__stat"><b>10+</b><span>Categories</span></div>
          <div class="imh__stat"><b>Fast</b><span>City Delivery</span></div>
        </div>
      {%- endif -%}
    </div>
    <div class="imh__media">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1100 }}" alt="{{ section.settings.heading | strip_html | escape }}" width="1100" loading="eager">
      {%- else -%}
        <div class="imh__ph">
          <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="2" width="10" height="20" rx="2.5"/><line x1="10.5" y1="18.5" x2="13.5" y2="18.5"/></svg>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "iMobile Accessories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Premium Mobiles &" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (blue)", "default": "Accessories" },
    { "type": "text", "id": "text", "label": "Text", "default": "We deal in all mobile phones and accessories — genuine products, best prices, and fast delivery across Karachi." },
    { "type": "text", "id": "btn1_label", "label": "Button 1 label", "default": "Shop Now" },
    { "type": "url", "id": "btn1_link", "label": "Button 1 link" },
    { "type": "text", "id": "btn2_label", "label": "Button 2 label", "default": "Explore Collection" },
    { "type": "url", "id": "btn2_link", "label": "Button 2 link" },
    { "type": "checkbox", "id": "show_whatsapp", "label": "Show WhatsApp button", "default": true },
    { "type": "checkbox", "id": "show_stats", "label": "Show stats row", "default": true },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [{ "name": "iMobile — Hero" }]
}
{% endschema %}
