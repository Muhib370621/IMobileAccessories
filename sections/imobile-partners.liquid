{%- comment -%} iMobile Accessories — Brand partners marquee {%- endcomment -%}
{%- assign names = section.settings.brands | split: ',' -%}
<style>
  #imp2-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: {{ section.settings.background }}; }
  #imp2-{{ section.id }} .imp2__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imp2-{{ section.id }} .imp2__eyebrow { text-align:center; font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.72rem; font-weight:700; color:#8a94a6; margin-bottom:22px; }
  #imp2-{{ section.id }} .imp2__mask { overflow:hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); }
  #imp2-{{ section.id }} .imp2__track { display:flex; width:max-content; align-items:center; gap:56px; animation: imp2-scroll {{ section.settings.speed }}s linear infinite; }
  #imp2-{{ section.id }} .imp2__track:hover { animation-play-state: paused; }
  #imp2-{{ section.id }} .imp2__item { font-family: var(--font-heading--family, sans-serif); font-weight:700; font-size:1.25rem; color:#aab2c0; white-space:nowrap; letter-spacing:0.02em; }
  @keyframes imp2-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce){ #imp2-{{ section.id }} .imp2__track{ animation:none; } }
</style>
<section id="imp2-{{ section.id }}">
  <div class="imp2__inner">
    {%- if section.settings.eyebrow != blank -%}<div class="imp2__eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
    <div class="imp2__mask">
      <div class="imp2__track">
        {%- for n in (1..2) -%}
          {%- for b in names -%}
            {%- assign t = b | strip -%}
            {%- if t != blank -%}<span class="imp2__item">{{ t }}</span>{%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Partners",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Brands" },
    { "type": "text", "id": "brands", "label": "Brand names (comma separated)", "default": "Apple, Samsung, Xiaomi, Oppo, Vivo, Realme, Infinix, Anker, JBL, Baseus" },
    { "type": "color", "id": "background", "label": "Background", "default": "#f6f7f9" },
    { "type": "range", "id": "speed", "label": "Scroll duration (s)", "min": 10, "max": 60, "step": 5, "default": 30 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 }
  ],
  "presets": [{ "name": "iMobile — Partners" }]
}
{% endschema %}
