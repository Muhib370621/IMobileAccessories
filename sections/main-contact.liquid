{%- comment -%} Contact page {%- endcomment -%}
{%- assign map_q = settings.address | url_encode -%}
<section class="section">
  <div class="container">
    <div class="collection-hero reveal"><span class="eyebrow">Contact</span><h1 class="mt-0">{{ page.title | default: 'Get in Touch' }}</h1></div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start" class="reveal">
      <div>
        {%- if page.content != blank -%}<div class="rte" style="margin-bottom:20px">{{ page.content }}</div>{%- endif -%}

        <div style="display:flex;gap:12px;align-items:flex-start;margin-bottom:16px">
          <span class="cat__ic" style="width:44px;height:44px;flex:0 0 44px">{% render 'icon', name: 'phone', size: 20 %}</span>
          <div><strong>Visit Our Shop</strong><br><span style="color:#6a7280">{{ settings.address }}</span></div>
        </div>
        <div style="display:flex;gap:12px;align-items:flex-start;margin-bottom:16px">
          <span class="cat__ic" style="width:44px;height:44px;flex:0 0 44px">{% render 'icon', name: 'whatsapp', size: 20 %}</span>
          <div><strong>WhatsApp / Call</strong><br><span style="color:#6a7280">{{ settings.whatsapp_1 }} &nbsp; {{ settings.whatsapp_2 }}</span></div>
        </div>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin:18px 0 26px">
          <a class="btn btn--wa" target="_blank" rel="noopener" href="https://wa.me/{{ settings.whatsapp_1_intl }}">{% render 'icon', name: 'whatsapp', size: 18 %} {{ settings.whatsapp_1 }}</a>
          <a class="btn btn--wa" target="_blank" rel="noopener" href="https://wa.me/{{ settings.whatsapp_2_intl }}">{% render 'icon', name: 'whatsapp', size: 18 %} {{ settings.whatsapp_2 }}</a>
        </div>

        {% form 'contact' %}
          {%- if form.posted_successfully? -%}<p style="color:#16a34a">Thanks! We’ll get back to you soon.</p>{%- endif -%}
          {%- if form.errors -%}<p style="color:#e11d48">Please check the form and try again.</p>{%- endif -%}
          <div style="display:grid;gap:12px;max-width:520px">
            <input type="text" name="contact[name]" placeholder="Your name" required style="padding:13px 15px;border:1px solid var(--muted);border-radius:var(--radius)">
            <input type="email" name="contact[email]" placeholder="Email" required style="padding:13px 15px;border:1px solid var(--muted);border-radius:var(--radius)">
            <textarea name="contact[body]" rows="4" placeholder="Message" required style="padding:13px 15px;border:1px solid var(--muted);border-radius:var(--radius)"></textarea>
            <button type="submit" class="btn btn--primary" style="justify-self:start">Send Message</button>
          </div>
        {% endform %}
      </div>

      <div style="border-radius:var(--card-radius);overflow:hidden;min-height:420px;border:1px solid var(--muted)">
        <iframe src="https://maps.google.com/maps?q={{ map_q }}&z=16&output=embed" width="100%" height="100%" style="border:0;min-height:420px;display:block" loading="lazy" title="Store location"></iframe>
      </div>
    </div>
  </div>
</section>
{% schema %}
{ "name": "Contact", "settings": [] }
{% endschema %}
