{%- comment -%} Category tiles {%- endcomment -%}
<section class="section reveal">
  <div class="container">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="cats stagger">
      {%- for block in section.blocks -%}
        {%- liquid
          assign h = block.settings.collection.url | default: ''
          if block.settings.collection != blank
            assign url = block.settings.collection.url
          else
            assign q = block.settings.title | url_encode
            assign url = routes.search_url | append: '?q=' | append: q
          endif
        -%}
        <a class="cat" href="{{ url }}" {{ block.shopify_attributes }}>
          <span class="cat__ic">{% render 'icon', name: block.settings.icon, size: 28 %}</span>
          <span>{{ block.settings.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Category Grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Category" }
  ],
  "blocks": [
    {
      "type": "cat",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Mobile Covers" },
        { "type": "collection", "id": "collection", "label": "Collection", "info": "If empty, links to a search for the title" },
        { "type": "select", "id": "icon", "label": "Icon", "default": "cover",
          "options": [
            {"value":"phone","label":"Phone"},{"value":"cover","label":"Cover"},{"value":"charger","label":"Charger"},
            {"value":"battery","label":"Power Bank"},{"value":"earbuds","label":"Earbuds"},{"value":"watch","label":"Watch"},
            {"value":"headphones","label":"Headphones"},{"value":"shield","label":"Screen Protector"},{"value":"cable","label":"Cable"},{"value":"star","label":"Accessory"}
          ] }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "cat", "settings": { "title": "Mobile Phones", "icon": "phone" } },
        { "type": "cat", "settings": { "title": "Mobile Covers", "icon": "cover" } },
        { "type": "cat", "settings": { "title": "Chargers", "icon": "charger" } },
        { "type": "cat", "settings": { "title": "Power Banks", "icon": "battery" } },
        { "type": "cat", "settings": { "title": "Earbuds", "icon": "earbuds" } },
        { "type": "cat", "settings": { "title": "Smart Watches", "icon": "watch" } },
        { "type": "cat", "settings": { "title": "Headphones", "icon": "headphones" } },
        { "type": "cat", "settings": { "title": "Screen Protectors", "icon": "shield" } },
        { "type": "cat", "settings": { "title": "Data Cables", "icon": "cable" } },
        { "type": "cat", "settings": { "title": "Accessories", "icon": "star" } }
      ]
    }
  ]
}
{% endschema %}
