{%- comment -%} iMobile Accessories — Exclusive Collections grid with counts {%- endcomment -%}
{%- liquid
  assign colls = section.settings.collection_list
  if colls == blank or colls.count == 0
    assign colls = collections
  endif
-%}
<style>
  #imcol-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: #0d0d0f; color:#fff; }
  #imcol-{{ section.id }} .imcol__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imcol-{{ section.id }} .imcol__head { text-align:center; margin-bottom: 34px; }
  #imcol-{{ section.id }} .imcol__eyebrow { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.74rem; font-weight:700; color:#ff5a5f; display:block; margin-bottom:8px; }
  #imcol-{{ section.id }} .imcol__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.6rem,3.5vw,2.4rem); margin:0; }
  #imcol-{{ section.id }} .imcol__grid { display:grid; grid-template-columns: repeat(4,1fr); gap:18px; }
  #imcol-{{ section.id }} .imcol__card { position:relative; display:block; border-radius:18px; overflow:hidden; text-decoration:none; aspect-ratio: 3/4; background:#1a0508; }
  #imcol-{{ section.id }} .imcol__card img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; transition: transform .6s cubic-bezier(0.22,1,0.36,1); }
  #imcol-{{ section.id }} .imcol__card:hover img { transform: scale(1.08); }
  #imcol-{{ section.id }} .imcol__ph { position:absolute; inset:0; display:grid; place-items:center; background:linear-gradient(135deg,#d90429,#0d0d0f); color:rgba(255,255,255,0.5); }
  #imcol-{{ section.id }} .imcol__ph svg { width:38%; }
  #imcol-{{ section.id }} .imcol__overlay { position:absolute; inset:0; background:linear-gradient(180deg, rgba(11,30,61,0) 35%, rgba(11,30,61,0.85) 100%); z-index:1; }
  #imcol-{{ section.id }} .imcol__meta { position:absolute; left:0; right:0; bottom:0; z-index:2; padding:18px; }
  #imcol-{{ section.id }} .imcol__count { display:inline-block; background:#d90429; color:#fff; font-family: var(--font-accent--family, sans-serif); font-size:0.7rem; font-weight:700; padding:4px 10px; border-radius:999px; margin-bottom:8px; }
  #imcol-{{ section.id }} .imcol__name { font-family: var(--font-heading--family, sans-serif); font-size:1.05rem; color:#fff; margin:0; }
  @media (max-width: 990px) { #imcol-{{ section.id }} .imcol__grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 480px) { #imcol-{{ section.id }} .imcol__grid { gap:12px; } }
</style>
<section id="imcol-{{ section.id }}">
  <div class="imcol__inner">
    <div class="imcol__head">
      {%- if section.settings.eyebrow != blank -%}<span class="imcol__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="imcol__title">{{ section.settings.heading }}</h2>
    </div>
    <div class="imcol__grid">
      {%- for collection in colls limit: section.settings.max -%}
        {%- liquid
          assign img = collection.image
          if img == blank
            assign img = collection.products.first.featured_image
          endif
        -%}
        <a class="imcol__card" href="{{ collection.url }}">
          {%- if img != blank -%}
            <img src="{{ img | image_url: width: 500 }}" alt="{{ collection.title | escape }}" width="500" loading="lazy">
          {%- else -%}
            <span class="imcol__ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="7" y="2" width="10" height="20" rx="2.5"/></svg></span>
          {%- endif -%}
          <span class="imcol__overlay"></span>
          <span class="imcol__meta">
            <span class="imcol__count">{{ collection.products_count }} {% if collection.products_count == 1 %}Item{% else %}Items{% endif %}</span>
            <h3 class="imcol__name">{{ collection.title }}</h3>
          </span>
        </a>
      {%- else -%}
        {% render 'im-empty-state', title: 'No Collections Yet', text: 'Collections will appear here once they are created in the store.' %}
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Collections",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Exclusive Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop Our Collections" },
    { "type": "collection_list", "id": "collection_list", "label": "Collections", "info": "Leave empty to auto-list your store collections" },
    { "type": "range", "id": "max", "label": "Max collections", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [{ "name": "iMobile — Collections" }]
}
{% endschema %}
