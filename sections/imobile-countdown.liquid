{%- comment -%} iMobile Accessories — Big Sale banner with countdown {%- endcomment -%}
<style>
  #imcd-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: var(--color-background); }
  #imcd-{{ section.id }} .imcd__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imcd-{{ section.id }} .imcd__band {
    border-radius:24px; padding:48px 40px; text-align:center; position:relative; overflow:hidden;
    background: linear-gradient(135deg, #0d0d0f 0%, #d90429 100%); color:#fff;
  }
  #imcd-{{ section.id }} .imcd__band::after { content:""; position:absolute; left:-80px; bottom:-80px; width:320px; height:320px; border-radius:50%; background:radial-gradient(circle, rgba(255,255,255,0.08), transparent 70%); }
  #imcd-{{ section.id }} .imcd__eyebrow { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.74rem; font-weight:700; color:#ffb020; display:block; margin-bottom:12px; }
  #imcd-{{ section.id }} .imcd__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.6rem,4vw,2.6rem); margin:0 0 22px; position:relative; }
  #imcd-{{ section.id }} .imcd__timer { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; margin-bottom:26px; position:relative; }
  #imcd-{{ section.id }} .imcd__unit { background:rgba(255,255,255,0.10); border:1px solid rgba(255,255,255,0.14); border-radius:14px; min-width:80px; padding:14px 10px; }
  #imcd-{{ section.id }} .imcd__num { font-family: var(--font-heading--family, sans-serif); font-size:2rem; font-weight:700; line-height:1; }
  #imcd-{{ section.id }} .imcd__lbl { font-size:0.72rem; text-transform:uppercase; letter-spacing:0.08em; opacity:0.7; margin-top:6px; }
  #imcd-{{ section.id }} .imcd__btn { position:relative; display:inline-flex; align-items:center; gap:10px; background:#fff; color:#0d0d0f; text-decoration:none; font-family: var(--font-accent--family, sans-serif); font-weight:600; font-size:0.92rem; padding:14px 30px; border-radius:6px; transition: transform .25s cubic-bezier(0.22,1,0.36,1); }
  #imcd-{{ section.id }} .imcd__btn:hover { transform: translateY(-3px); }
</style>
<section id="imcd-{{ section.id }}">
  <div class="imcd__inner">
    <div class="imcd__band">
      {%- if section.settings.eyebrow != blank -%}<span class="imcd__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="imcd__title">{{ section.settings.heading }}</h2>
      <div class="imcd__timer" id="imcd-timer-{{ section.id }}" data-deadline="{{ section.settings.deadline }}" data-days="{{ section.settings.fallback_days }}">
        <div class="imcd__unit"><div class="imcd__num" data-d>00</div><div class="imcd__lbl">Days</div></div>
        <div class="imcd__unit"><div class="imcd__num" data-h>00</div><div class="imcd__lbl">Hours</div></div>
        <div class="imcd__unit"><div class="imcd__num" data-m>00</div><div class="imcd__lbl">Minutes</div></div>
        <div class="imcd__unit"><div class="imcd__num" data-s>00</div><div class="imcd__lbl">Seconds</div></div>
      </div>
      {%- if section.settings.btn_label != blank -%}
        <a class="imcd__btn" href="{{ section.settings.btn_link | default: '#' }}">{{ section.settings.btn_label }}</a>
      {%- endif -%}
    </div>
  </div>
  <script>
    (function(){
      var root = document.getElementById('imcd-timer-{{ section.id }}');
      if(!root) return;
      var deadlineStr = (root.getAttribute('data-deadline')||'').trim();
      var target;
      if(deadlineStr){ target = new Date(deadlineStr).getTime(); }
      if(!target || isNaN(target) || target < Date.now()){
        var days = parseInt(root.getAttribute('data-days')||'3',10);
        var key = 'imcd-{{ section.id }}';
        var saved = localStorage.getItem(key);
        if(saved && parseInt(saved,10) > Date.now()){ target = parseInt(saved,10); }
        else { target = Date.now() + days*86400000; localStorage.setItem(key, target); }
      }
      var dEl=root.querySelector('[data-d]'),hEl=root.querySelector('[data-h]'),mEl=root.querySelector('[data-m]'),sEl=root.querySelector('[data-s]');
      function pad(n){return (n<10?'0':'')+n;}
      function tick(){
        var diff = target - Date.now();
        if(diff<0) diff=0;
        var d=Math.floor(diff/86400000);
        var h=Math.floor(diff%86400000/3600000);
        var m=Math.floor(diff%3600000/60000);
        var s=Math.floor(diff%60000/1000);
        dEl.textContent=pad(d);hEl.textContent=pad(h);mEl.textContent=pad(m);sEl.textContent=pad(s);
      }
      tick(); setInterval(tick,1000);
    })();
  </script>
</section>
{% schema %}
{
  "name": "iMobile Countdown Sale",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Big Sale Alert" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Last Chance to Get Up to 50% Off!" },
    { "type": "text", "id": "deadline", "label": "Deadline (YYYY-MM-DD HH:MM)", "info": "Leave empty to auto-repeat a rolling countdown" },
    { "type": "range", "id": "fallback_days", "label": "Rolling countdown length (days)", "min": 1, "max": 30, "step": 1, "default": 3 },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop All" },
    { "type": "url", "id": "btn_link", "label": "Button link" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 }
  ],
  "presets": [{ "name": "iMobile — Countdown Sale" }]
}
{% endschema %}
