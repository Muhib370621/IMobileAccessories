{%- comment -%} Scrolling marquee {%- endcomment -%}
{%- assign items = section.settings.text | split: '•' -%}
<div class="marquee" style="{% if section.settings.bg != blank %}background:{{ section.settings.bg }};{% endif %}">
  <div class="marquee__track">
    {%- for i in (1..2) -%}
      {%- for it in items -%}{%- assign t = it | strip -%}{%- if t != blank -%}<span class="marquee__item">{{ t }} <span aria-hidden="true">•</span></span>{%- endif -%}{%- endfor -%}
    {%- endfor -%}
  </div>
</div>
{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "text", "id": "text", "label": "Text (separate with •)", "default": "Original Products • Best Prices in Karachi • Fast Delivery • Genuine Warranty • iMobile Accessories" },
    { "type": "color", "id": "bg", "label": "Background" }
  ],
  "presets": [{ "name": "Marquee" }]
}
{% endschema %}
