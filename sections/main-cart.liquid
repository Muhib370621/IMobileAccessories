{%- comment -%} Cart page {%- endcomment -%}
<section class="section cart-page">
  <div class="container" style="max-width:900px">
    <h1>{{ 'cart.title' | t }}</h1>
    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="cartForm">
        {%- for item in cart.items -%}
          <div class="cart-row">
            <a href="{{ item.url }}">
              {%- if item.image -%}<img src="{{ item.image | image_url: width: 180 }}" alt="{{ item.title | escape }}">{%- endif -%}
            </a>
            <div>
              <a href="{{ item.url }}" style="font-weight:600">{{ item.product.title }}</a>
              {%- unless item.variant.title contains 'Default' -%}<div style="color:#6a7280;font-size:.88rem">{{ item.variant.title }}</div>{%- endunless -%}
              <div class="price" style="margin-top:6px"><span class="price__now">{{ item.final_line_price | money }}</span></div>
              <a href="{{ item.url_to_remove }}" style="color:#e11d48;font-size:.82rem">{{ 'cart.remove' | t }}</a>
            </div>
            <div class="qty">
              <a class="btn" href="{{ item.url_to_change }}&quantity={{ item.quantity | minus: 1 }}" style="width:42px;height:48px;padding:0;background:#fff;color:var(--heading);border-radius:0">−</a>
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity" style="border-left:1px solid var(--muted);border-right:1px solid var(--muted)">
              <a class="btn" href="{{ item.url_to_change }}&quantity={{ item.quantity | plus: 1 }}" style="width:42px;height:48px;padding:0;background:#fff;color:var(--heading);border-radius:0">+</a>
            </div>
          </div>
        {%- endfor -%}

        <div class="cart-summary">
          <button type="submit" name="update" class="btn btn--outline">Update cart</button>
          <div class="cart-total">{{ 'cart.subtotal' | t }}: {{ cart.total_price | money }}</div>
          <button type="submit" name="checkout" class="btn btn--primary" style="min-width:220px">{{ 'cart.checkout' | t }}</button>
        </div>
      </form>
    {%- else -%}
      <p class="empty">{{ 'cart.empty' | t }}</p>
      <div class="text-center"><a class="btn btn--primary" href="{{ routes.all_products_collection_url }}">{{ 'cart.continue' | t }}</a></div>
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
