{%- comment -%} Collection page {%- endcomment -%}
{%- paginate collection.products by 24 -%}
<section class="section">
  <div class="container">
    <div class="collection-hero reveal">
      <span class="eyebrow">Collection</span>
      <h1 class="mt-0">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}<p style="max-width:60ch;margin-inline:auto;color:#6a7280">{{ collection.description | strip_html | truncatewords: 40 }}</p>{%- endif -%}
    </div>

    <div class="toolbar">
      <span>{{ collection.products_count }} {{ 'collection.products' | t }}</span>
      <form method="get">
        <label class="visually-hidden" for="sort">{{ 'collection.sort' | t }}</label>
        <select id="sort" name="sort_by" onchange="this.form.submit()">
          {%- assign sorts = collection.sort_options -%}
          {%- for opt in sorts -%}
            <option value="{{ opt.value }}" {% if collection.sort_by == opt.value or collection.default_sort_by == opt.value and collection.sort_by == blank %}selected{% endif %}>{{ opt.name }}</option>
          {%- endfor -%}
        </select>
      </form>
    </div>

    {%- if collection.products.size > 0 -%}
      <div class="grid grid--4 stagger">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div style="display:flex;justify-content:center;gap:8px;margin-top:40px">
          {%- if paginate.previous -%}<a class="btn btn--outline" href="{{ paginate.previous.url }}">← Prev</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a class="btn btn--outline" href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}<span class="btn btn--primary">{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a class="btn btn--outline" href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <p class="empty">{{ 'collection.empty' | t }}</p>
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}
{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
