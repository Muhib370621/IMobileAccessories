{%- comment -%} iMobile Accessories — Brand statement {%- endcomment -%}
<style>
  #imab-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: {{ section.settings.background }}; }
  #imab-{{ section.id }} .imab__inner { max-width: 820px; margin-inline:auto; padding-inline:20px; text-align:center; }
  #imab-{{ section.id }} .imab__eyebrow { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.72rem; font-weight:700; color:#8a94a6; display:block; margin-bottom:14px; }
  #imab-{{ section.id }} .imab__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.7rem,4vw,2.7rem); margin:0 0 18px; color:#222325; line-height:1.15; }
  #imab-{{ section.id }} .imab__text { color:#5f6773; font-size:1.05rem; line-height:1.7; margin:0 auto 28px; max-width:60ch; }
  #imab-{{ section.id }} .imab__btn { display:inline-flex; align-items:center; gap:9px; background:#2d3645; color:#fff; text-decoration:none; font-family: var(--font-accent--family, sans-serif); font-weight:600; font-size:0.92rem; padding:14px 30px; border-radius:6px; transition: transform .25s cubic-bezier(0.22,1,0.36,1), background .25s; }
  #imab-{{ section.id }} .imab__btn:hover { transform: translateY(-3px); background:#222325; }
</style>
<section id="imab-{{ section.id }}">
  <div class="imab__inner">
    {%- if section.settings.eyebrow != blank -%}<span class="imab__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h2 class="imab__title">{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}<p class="imab__text">{{ section.settings.text }}</p>{%- endif -%}
    {%- if section.settings.btn_label != blank -%}
      <a class="imab__btn" href="{{ section.settings.btn_link | default: '#' }}">{{ section.settings.btn_label }}</a>
    {%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "iMobile Brand Statement",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "About Us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A Store Committed to Genuine Products" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "iMobile Accessories deals in all mobile phones and accessories. We focus on genuine products, honest prices and friendly service — so you can shop with complete confidence." },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Contact Us" },
    { "type": "url", "id": "btn_link", "label": "Button link" },
    { "type": "color", "id": "background", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 140, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [{ "name": "iMobile — Brand Statement" }]
}
{% endschema %}
