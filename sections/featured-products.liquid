{%- comment -%} Featured products grid {%- endcomment -%}
{%- liquid
  assign coll = section.settings.collection
  if coll != blank and coll.products_count > 0
    assign products = coll.products
  else
    assign products = collections.all.products
  endif
-%}
<section class="section reveal"{% if section.settings.bg != blank %} style="background:{{ section.settings.bg }}"{% endif %}>
  <div class="container">
    <div class="toolbar">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2 class="mt-0">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.show_view_all -%}
        <a class="btn btn--outline" href="{% if coll != blank %}{{ coll.url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}">View all</a>
      {%- endif -%}
    </div>
    <div class="grid grid--4 stagger">
      {%- for product in products limit: section.settings.max -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p class="empty">No products yet. Add products to your store to see them here.</p>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bestsellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trending Now" },
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Empty = all products" },
    { "type": "range", "id": "max", "label": "Products", "min": 4, "max": 16, "step": 4, "default": 8 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view all", "default": true },
    { "type": "color", "id": "bg", "label": "Background", "default": "#ffffff" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
