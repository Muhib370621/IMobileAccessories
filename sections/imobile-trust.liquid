{%- comment -%} iMobile Accessories — Trust badges bar {%- endcomment -%}
{%- liquid
  assign items = section.settings.items | newline_to_br | split: '<br />'
-%}
<style>
  #imtrust-{{ section.id }} {
    padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    background: linear-gradient(135deg, #0b1e3d 0%, #10305c 55%, #0099e6 160%);
    color: #fff;
  }
  #imtrust-{{ section.id }} .imtrust__inner {
    max-width: var(--page-width, 1400px);
    margin-inline: auto;
    padding-inline: 20px;
  }
  #imtrust-{{ section.id }} .imtrust__head { text-align: center; margin-bottom: 34px; }
  #imtrust-{{ section.id }} .imtrust__title {
    font-family: var(--font-heading--family, sans-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    margin: 0 0 8px;
  }
  #imtrust-{{ section.id }} .imtrust__sub { margin: 0; opacity: 0.75; font-size: 0.95rem; }
  #imtrust-{{ section.id }} .imtrust__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
  }
  #imtrust-{{ section.id }} .imtrust__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    padding: 22px 12px;
    border-radius: 16px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.10);
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), background 0.4s;
  }
  #imtrust-{{ section.id }} .imtrust__card:hover { transform: translateY(-5px); background: rgba(255,255,255,0.12); }
  #imtrust-{{ section.id }} .imtrust__ic {
    width: 46px; height: 46px; display: grid; place-items: center;
    border-radius: 50%; background: rgba(0,153,230,0.25);
  }
  #imtrust-{{ section.id }} .imtrust__ic svg { width: 24px; height: 24px; }
  #imtrust-{{ section.id }} .imtrust__name { font-family: var(--font-body--family, sans-serif); font-weight: 600; font-size: 0.9rem; line-height: 1.2; }
  @media (max-width: 990px) { #imtrust-{{ section.id }} .imtrust__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 560px) { #imtrust-{{ section.id }} .imtrust__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } }
</style>
<section id="imtrust-{{ section.id }}">
  <div class="imtrust__inner">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="imtrust__head">
        {%- if section.settings.heading != blank -%}<h2 class="imtrust__title">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="imtrust__sub">{{ section.settings.subheading }}</p>{%- endif -%}
      </div>
    {%- endif -%}
    <div class="imtrust__grid">
      {%- for raw in items -%}
        {%- liquid
          assign line = raw | strip
          if line == blank
            continue
          endif
          assign parts = line | split: '|'
          assign label = parts[0] | strip
          assign ic = parts[1] | strip | default: 'check'
        -%}
        <div class="imtrust__card">
          <span class="imtrust__ic">{% render 'im-trust-icon', name: ic %}</span>
          <span class="imtrust__name">{{ label }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Trust Badges",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Shop With Us" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Trusted by customers across Karachi for genuine mobile products & accessories." },
    {
      "type": "textarea",
      "id": "items",
      "label": "Items (one per line: Label | icon)",
      "info": "icon options: original, quality, delivery, secure, support, returns",
      "default": "Original Products | original\nBest Quality | quality\nFast Delivery | delivery\nSecure Payments | secure\nCustomer Support | support\nEasy Returns | returns"
    },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [{ "name": "iMobile — Trust Badges" }]
}
{% endschema %}
