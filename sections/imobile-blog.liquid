{%- comment -%} iMobile Accessories — Newsroom / blog posts {%- endcomment -%}
{%- liquid
  assign blog = blogs[section.settings.blog]
  assign articles = blog.articles
-%}
<style>
  #imbl-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; background: var(--color-background); }
  #imbl-{{ section.id }} .imbl__inner { max-width: var(--page-width, 1400px); margin-inline:auto; padding-inline:20px; }
  #imbl-{{ section.id }} .imbl__head { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; margin-bottom:28px; }
  #imbl-{{ section.id }} .imbl__eyebrow { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.16em; font-size:0.72rem; font-weight:700; color:#8a94a6; display:block; margin-bottom:8px; }
  #imbl-{{ section.id }} .imbl__title { font-family: var(--font-heading--family, sans-serif); font-size: clamp(1.5rem,3.5vw,2.3rem); margin:0; color:#222325; }
  #imbl-{{ section.id }} .imbl__all { font-family: var(--font-accent--family, sans-serif); font-size:0.85rem; font-weight:600; color:#fff; background:#222325; text-decoration:none; padding:11px 20px; border-radius:6px; white-space:nowrap; transition: background .25s, transform .2s; }
  #imbl-{{ section.id }} .imbl__all:hover { background:#2d3645; transform: translateY(-2px); }
  #imbl-{{ section.id }} .imbl__grid { display:grid; grid-template-columns: repeat(3,1fr); gap:22px; }
  #imbl-{{ section.id }} .imbl__card { display:flex; flex-direction:column; border:1px solid #e7e9ee; border-radius:16px; overflow:hidden; background:#fff; text-decoration:none; transition: transform .4s cubic-bezier(0.22,1,0.36,1), box-shadow .4s; }
  #imbl-{{ section.id }} .imbl__card:hover { transform: translateY(-5px); box-shadow: 0 22px 40px -24px rgba(34,35,37,0.3); }
  #imbl-{{ section.id }} .imbl__media { aspect-ratio: 16/10; background:#eef0f4; overflow:hidden; }
  #imbl-{{ section.id }} .imbl__media img { width:100%; height:100%; object-fit:cover; transition: transform .6s cubic-bezier(0.22,1,0.36,1); }
  #imbl-{{ section.id }} .imbl__card:hover .imbl__media img { transform: scale(1.06); }
  #imbl-{{ section.id }} .imbl__ph { width:100%; height:100%; display:grid; place-items:center; background:linear-gradient(135deg,#3a4152,#222325); color:rgba(255,255,255,0.4); }
  #imbl-{{ section.id }} .imbl__ph svg { width:26%; max-width:60px; }
  #imbl-{{ section.id }} .imbl__body { padding:20px; display:flex; flex-direction:column; gap:10px; flex:1; }
  #imbl-{{ section.id }} .imbl__date { font-family: var(--font-accent--family, sans-serif); text-transform:uppercase; letter-spacing:0.08em; font-size:0.7rem; color:#8a94a6; font-weight:600; }
  #imbl-{{ section.id }} .imbl__ptitle { font-family: var(--font-heading--family, sans-serif); font-size:1.1rem; color:#222325; margin:0; line-height:1.3; }
  #imbl-{{ section.id }} .imbl__excerpt { color:#6a7280; font-size:0.9rem; line-height:1.55; margin:0; }
  #imbl-{{ section.id }} .imbl__more { font-family: var(--font-accent--family, sans-serif); font-size:0.82rem; font-weight:600; color:#222325; margin-top:auto; }
  @media (max-width:900px){ #imbl-{{ section.id }} .imbl__grid{ grid-template-columns:1fr; } }
</style>
<section id="imbl-{{ section.id }}">
  <div class="imbl__inner">
    <div class="imbl__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="imbl__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2 class="imbl__title">{{ section.settings.heading }}</h2>
      </div>
      {%- if blog != blank -%}<a class="imbl__all" href="{{ blog.url }}">Explore Newsroom</a>{%- endif -%}
    </div>
    <div class="imbl__grid">
      {%- if articles.size > 0 -%}
        {%- for article in articles limit: section.settings.max -%}
          <a class="imbl__card" href="{{ article.url }}">
            <span class="imbl__media">
              {%- if article.image -%}
                <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" loading="lazy">
              {%- else -%}
                <span class="imbl__ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M4 5h16v14H4z"/><path d="M4 9h16"/></svg></span>
              {%- endif -%}
            </span>
            <span class="imbl__body">
              <span class="imbl__date">{{ article.published_at | date: "%d %b %Y" }}</span>
              <span class="imbl__ptitle">{{ article.title }}</span>
              <span class="imbl__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</span>
              <span class="imbl__more">Read More →</span>
            </span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="imbl__card">
            <span class="imbl__media"><span class="imbl__ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M4 5h16v14H4z"/><path d="M4 9h16"/></svg></span></span>
            <span class="imbl__body">
              <span class="imbl__date">Coming Soon</span>
              <span class="imbl__ptitle">Your blog post title</span>
              <span class="imbl__excerpt">Publish articles in your Shopify blog to show the latest tips and news here.</span>
              <span class="imbl__more">Read More →</span>
            </span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "iMobile Newsroom",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Newsroom" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay Informed, Stay Inspired" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "max", "label": "Posts to show", "min": 3, "max": 6, "step": 3, "default": 3 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "presets": [{ "name": "iMobile — Newsroom" }]
}
{% endschema %}
