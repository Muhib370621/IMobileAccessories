{%- comment -%} Floating WhatsApp + back-to-top {%- endcomment -%}
{%- assign wa_msg = 'Assalam-o-Alaikum! Mujhe iMobile Accessories se maloomat chahiye.' | url_encode -%}
<a class="fab-wa" href="https://wa.me/{{ settings.whatsapp_1_intl }}?text={{ wa_msg }}" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
  {% render 'icon', name: 'whatsapp', size: 30 %}
</a>
<button class="to-top" id="toTop" type="button" aria-label="Back to top">{% render 'icon', name: 'arrow-up', size: 20 %}</button>
