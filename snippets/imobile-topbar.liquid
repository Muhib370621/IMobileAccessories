{%- comment -%} iMobile Accessories — slim top info bar (above header) {%- endcomment -%}
<style>
  .im-topbar {
    background: linear-gradient(90deg, #0d0d0f, #2a060c);
    color: #fff;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.8rem;
  }
  .im-topbar__inner {
    max-width: var(--page-width, 1400px);
    margin-inline: auto;
    padding: 7px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .im-topbar__tag { opacity: 0.9; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .im-topbar__contact { display: flex; align-items: center; gap: 16px; white-space: nowrap; }
  .im-topbar__link {
    display: inline-flex; align-items: center; gap: 6px;
    color: #fff; text-decoration: none; font-weight: 600;
    transition: color 0.25s ease;
  }
  .im-topbar__link:hover { color: #25D366; }
  .im-topbar__link svg { width: 14px; height: 14px; }
  .im-topbar__wa { color: #4ee585; }
  @media (max-width: 749px) {
    .im-topbar__tag { display: none; }
    .im-topbar__inner { justify-content: center; padding: 6px 14px; }
    .im-topbar__contact { gap: 14px; font-size: 0.78rem; }
  }
</style>
<div class="im-topbar">
  <div class="im-topbar__inner">
    <span class="im-topbar__tag">We deal in all mobile phones and accessories</span>
    <span class="im-topbar__contact">
      <a class="im-topbar__link" href="https://wa.me/923152972723" target="_blank" rel="noopener">
        <span class="im-topbar__wa">{% render 'im-wa-icon', size: 14 %}</span> 0315-2972723
      </a>
      <a class="im-topbar__link" href="https://wa.me/923482532992" target="_blank" rel="noopener">
        <span class="im-topbar__wa">{% render 'im-wa-icon', size: 14 %}</span> 0348-2532992
      </a>
    </span>
  </div>
</div>
