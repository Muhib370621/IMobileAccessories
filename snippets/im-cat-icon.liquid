{%- comment -%} iMobile category line icons. Param: name {%- endcomment -%}
{%- liquid
  assign n = name | default: 'accessory'
-%}
{%- case n -%}
  {%- when 'phone' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="2" width="10" height="20" rx="2.5"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
  {%- when 'cover' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="2" width="12" height="20" rx="3"/><rect x="9" y="5" width="6" height="9" rx="1.2"/><circle cx="16" cy="6" r="0.9" fill="currentColor" stroke="none"/></svg>
  {%- when 'charger' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2v5M15 2v5"/><path d="M6 7h12v3a6 6 0 0 1-12 0Z"/><path d="M12 16v6"/></svg>
  {%- when 'powerbank' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5" width="16" height="14" rx="2.5"/><path d="M12 8l-2 4h3l-2 4"/></svg>
  {%- when 'earbuds' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 8a3 3 0 0 0-3 3v1a2.5 2.5 0 0 0 5 0V9"/><path d="M16 8a3 3 0 0 1 3 3v1a2.5 2.5 0 0 1-5 0V9"/><path d="M10 9v9M14 9v9"/></svg>
  {%- when 'watch' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="7" width="10" height="10" rx="3"/><path d="M9 7l.5-4h5L15 7M9 17l.5 4h5l.5-4"/><path d="M12 10v2.5l1.5 1"/></svg>
  {%- when 'headphones' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14v-2a8 8 0 0 1 16 0v2"/><rect x="3" y="13" width="4" height="7" rx="1.6"/><rect x="17" y="13" width="4" height="7" rx="1.6"/></svg>
  {%- when 'screen' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V5Z"/><path d="M9.5 12l1.8 1.8L15 10"/></svg>
  {%- when 'cable' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3v4M17 17v4"/><rect x="5" y="7" width="4" height="4" rx="1"/><rect x="15" y="13" width="4" height="4" rx="1"/><path d="M7 11v3a3 3 0 0 0 3 3h4"/></svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.2 4.8L19 9l-3.5 3.4L16 18l-4-2.3L8 18l.5-5.6L5 9l4.8-1.2Z"/></svg>
{%- endcase -%}
