  {%- when 'whatsapp' -%}<svg width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.71 14.03c-.24.68-1.2 1.24-1.68 1.28-.43.06-.97.08-1.56-.1-.36-.11-.82-.26-1.41-.51-2.48-1.08-4.11-3.58-4.23-3.75-.12-.16-1.01-1.34-1.01-2.56 0-1.22.63-1.82.86-2.07.23-.25.5-.31.66-.31.17 0 .34 0 .48.01.16.01.36-.06.56.43.2.5.7 1.72.76 1.84.06.12.1.26.02.43-.08.16-.12.26-.25.41-.13.14-.27.32-.38.43-.13.13-.26.27-.11.52.15.25.66 1.09 1.42 1.76.98.87 1.79 1.14 2.04 1.27.25.13.4.11.55-.06.15-.16.63-.73.8-.98.16-.25.33-.21.55-.13.23.08 1.44.68 1.69.8.25.13.41.19.47.29.06.11.06.6-.18 1.28Z"/></svg>
