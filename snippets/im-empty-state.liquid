{%- comment -%}
  Graphical empty state. Params: title, text
  Shows an illustrated "nothing found" widget with actions.
{%- endcomment -%}
{%- liquid
  assign es_title = title | default: 'Nothing Found'
  assign es_text = text | default: 'We could not find any products here right now. Check back soon or browse everything.'
  assign wa_msg = 'Assalam-o-Alaikum! Mujhe iMobile Accessories se maloomat chahiye.' | url_encode
-%}
<style>
  .im-empty { grid-column: 1 / -1; display:flex; flex-direction:column; align-items:center; text-align:center; padding: 44px 20px 52px; }
  .im-empty__art { width: 150px; height: 150px; margin-bottom: 20px; animation: imEmptyFloat 3.4s ease-in-out infinite; }
  @keyframes imEmptyFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
  .im-empty__art .lens { animation: imEmptyScan 3.4s ease-in-out infinite; transform-origin: 60% 60%; }
  @keyframes imEmptyScan { 0%,100% { transform: rotate(0deg); } 50% { transform: rotate(-14deg); } }
  .im-empty__title { font-family: var(--font-heading--family, sans-serif); font-size: 1.35rem; margin: 0 0 8px; color: #0d0d0f; }
  .im-empty__text { margin: 0 0 22px; color: #7a828f; max-width: 44ch; line-height: 1.6; }
  .im-empty__btns { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .im-empty__btn { display:inline-flex; align-items:center; gap:8px; text-decoration:none; font-family: var(--font-accent--family, sans-serif); font-weight:600; font-size:.9rem; padding:12px 24px; border-radius:6px; transition: transform .25s cubic-bezier(0.22,1,0.36,1), box-shadow .25s; }
  .im-empty__btn--primary { background: linear-gradient(120deg, #d90429, #7a0216); color:#fff; }
  .im-empty__btn--primary:hover { transform: translateY(-2px); box-shadow: 0 12px 24px -10px rgba(217,4,41,.6); }
  .im-empty__btn--wa { background:#25D366; color:#fff; }
  .im-empty__btn--wa:hover { transform: translateY(-2px); }
  @media (prefers-reduced-motion: reduce) { .im-empty__art, .im-empty__art .lens { animation: none; } }
</style>
<div class="im-empty" role="status">
  <svg class="im-empty__art" viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- open box -->
    <rect x="30" y="72" width="76" height="52" rx="6" fill="#f3f4f6" stroke="#d3d7de" stroke-width="2.5"/>
    <path d="M30 78 L14 58 L52 50 L68 72 Z" fill="#e8eaee" stroke="#d3d7de" stroke-width="2.5" stroke-linejoin="round"/>
    <path d="M106 78 L122 58 L84 50 L68 72 Z" fill="#dfe2e8" stroke="#d3d7de" stroke-width="2.5" stroke-linejoin="round"/>
    <line x1="68" y1="72" x2="68" y2="124" stroke="#d3d7de" stroke-width="2.5"/>
    <!-- dashed "missing item" -->
    <rect x="46" y="88" width="18" height="24" rx="3" stroke="#c3c8d1" stroke-width="2" stroke-dasharray="4 4"/>
    <rect x="74" y="88" width="18" height="24" rx="3" stroke="#c3c8d1" stroke-width="2" stroke-dasharray="4 4"/>
    <!-- magnifier -->
    <g class="lens">
      <circle cx="112" cy="96" r="24" fill="rgba(217,4,41,0.06)" stroke="#d90429" stroke-width="4"/>
      <line x1="129" y1="113" x2="146" y2="130" stroke="#d90429" stroke-width="6" stroke-linecap="round"/>
      <path d="M102 92 q10 -10 20 0" stroke="#d90429" stroke-width="3" stroke-linecap="round" fill="none" opacity=".5"/>
    </g>
    <!-- sparkles -->
    <path d="M28 34 l2.5 6 6 2.5 -6 2.5 -2.5 6 -2.5 -6 -6 -2.5 6 -2.5 Z" fill="#d90429" opacity=".55"/>
    <circle cx="132" cy="36" r="4" fill="#d90429" opacity=".35"/>
    <circle cx="18" cy="108" r="3" fill="#c3c8d1"/>
  </svg>
  <h3 class="im-empty__title">{{ es_title }}</h3>
  <p class="im-empty__text">{{ es_text }}</p>
  <div class="im-empty__btns">
    <a class="im-empty__btn im-empty__btn--primary" href="{{ routes.all_products_collection_url }}">Browse All Products</a>
    <a class="im-empty__btn im-empty__btn--wa" target="_blank" rel="noopener" href="https://wa.me/923152972723?text={{ wa_msg }}">{% render 'im-wa-icon', size: 17 %} Ask on WhatsApp</a>
  </div>
</div>
