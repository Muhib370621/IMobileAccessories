{%- comment -%}
  iMobile Accessories — global enhancements
  - Floating WhatsApp contact (both numbers)
  - Lightweight, elegant animations (scroll reveal, fade/slide, hover, image zoom)
  - Smooth scrolling + page load fade
  All animations are progressive-enhancement: they only activate once JS adds
  `imobile-ready` to <html>, so if JS fails nothing is ever hidden.
{%- endcomment -%}

<style>
  :root {
    --im-wa-green: #25D366;
    --im-ease: cubic-bezier(0.22, 1, 0.36, 1);
  }

  html { scroll-behavior: smooth; }

  /* ---------- Page load fade ---------- */
  html.imobile-ready body { animation: imFadeIn 0.6s var(--im-ease) both; }
  @keyframes imFadeIn { from { opacity: 0; } to { opacity: 1; } }

  /* ---------- Scroll reveal (sections) ---------- */
  html.imobile-ready .im-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s var(--im-ease), transform 0.7s var(--im-ease);
    will-change: opacity, transform;
  }
  html.imobile-ready .im-reveal.im-in {
    opacity: 1;
    transform: none;
  }

  /* ---------- Premium hover: product & collection cards ---------- */
  .product-card,
  .card-gallery,
  .resource-card,
  .collection-card {
    transition: transform 0.4s var(--im-ease), box-shadow 0.4s var(--im-ease);
  }
  .product-card:hover,
  .resource-card:hover,
  .collection-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px -18px rgba(11, 30, 61, 0.35);
  }

  /* ---------- Image zoom on hover ---------- */
  .product-card .media img,
  .card-gallery .media img,
  .resource-card .media img,
  .collection-card img,
  .product-media img {
    transition: transform 0.6s var(--im-ease);
  }
  .product-card:hover .media img,
  .card-gallery:hover .media img,
  .resource-card:hover .media img,
  .collection-card:hover img {
    transform: scale(1.06);
  }

  /* ---------- Button hover lift ---------- */
  .button,
  .button-secondary,
  button.button {
    transition: transform 0.25s var(--im-ease), box-shadow 0.25s var(--im-ease), background-color 0.25s var(--im-ease), color 0.25s var(--im-ease) !important;
  }
  .button:hover,
  .button-secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 22px -10px rgba(0, 153, 230, 0.6);
  }

  /* ---------- Floating WhatsApp ---------- */
  .im-wa {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 900;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }
  .im-wa__panel {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(10px) scale(0.96);
    transform-origin: bottom right;
    transition: max-height 0.35s var(--im-ease), opacity 0.3s var(--im-ease), transform 0.35s var(--im-ease);
    pointer-events: none;
  }
  .im-wa.im-open .im-wa__panel {
    max-height: 220px;
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .im-wa__link {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #ffffff;
    color: #222325;
    text-decoration: none;
    padding: 10px 16px 10px 12px;
    border-radius: 999px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.9rem;
    font-weight: 600;
    box-shadow: 0 10px 30px -8px rgba(11, 30, 61, 0.35);
    white-space: nowrap;
    animation: imFadeIn 0.4s var(--im-ease) both;
  }
  .im-wa__link small {
    display: block;
    font-weight: 400;
    font-size: 0.72rem;
    opacity: 0.65;
  }
  .im-wa__link .im-wa__dot {
    width: 34px;
    height: 34px;
    flex: 0 0 34px;
    border-radius: 50%;
    background: var(--im-wa-green);
    display: grid;
    place-items: center;
  }
  .im-wa__link:hover { transform: translateX(-4px); transition: transform 0.25s var(--im-ease); }
  .im-wa__toggle {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: var(--im-wa-green);
    color: #fff;
    display: grid;
    place-items: center;
    box-shadow: 0 12px 30px -6px rgba(37, 211, 102, 0.6);
    animation: imPulse 2.6s ease-in-out infinite;
    transition: transform 0.3s var(--im-ease);
  }
  .im-wa__toggle:hover { transform: scale(1.08); }
  .im-wa.im-open .im-wa__toggle { animation: none; }
  @keyframes imPulse {
    0%, 100% { box-shadow: 0 12px 30px -6px rgba(37, 211, 102, 0.55), 0 0 0 0 rgba(37, 211, 102, 0.5); }
    50% { box-shadow: 0 12px 30px -6px rgba(37, 211, 102, 0.55), 0 0 0 14px rgba(37, 211, 102, 0); }
  }

  @media (max-width: 749px) {
    .im-wa { right: 14px; bottom: 14px; }
    .im-wa__toggle { width: 54px; height: 54px; }
  }

  @media (prefers-reduced-motion: reduce) {
    html.imobile-ready body,
    html.imobile-ready .im-reveal { animation: none !important; opacity: 1 !important; transform: none !important; transition: none !important; }
    .im-wa__toggle { animation: none; }
    html { scroll-behavior: auto; }
  }
</style>

{%- assign wa_msg = 'Assalam-o-Alaikum! Mujhe iMobile Accessories se products ke baare mein maloomat chahiye.' | url_encode -%}
<div class="im-wa" id="im-wa">
  <div class="im-wa__panel" role="menu" aria-label="WhatsApp contact numbers">
    <a class="im-wa__link" href="https://wa.me/923152972723?text={{ wa_msg }}" target="_blank" rel="noopener" role="menuitem">
      <span class="im-wa__dot">{% render 'im-wa-icon' %}</span>
      <span>Chat now<small>0315-2972723</small></span>
    </a>
    <a class="im-wa__link" href="https://wa.me/923482532992?text={{ wa_msg }}" target="_blank" rel="noopener" role="menuitem">
      <span class="im-wa__dot">{% render 'im-wa-icon' %}</span>
      <span>Chat now<small>0348-2532992</small></span>
    </a>
  </div>
  <button class="im-wa__toggle" id="im-wa-toggle" type="button" aria-expanded="false" aria-label="Contact us on WhatsApp">
    {% render 'im-wa-icon', size: 30 %}
  </button>
</div>

<script>
  (function () {
    var root = document.documentElement;
    root.classList.add('imobile-ready');

    // WhatsApp toggle
    var wa = document.getElementById('im-wa');
    var toggle = document.getElementById('im-wa-toggle');
    if (wa && toggle) {
      toggle.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = wa.classList.toggle('im-open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', function (e) {
        if (!wa.contains(e.target)) {
          wa.classList.remove('im-open');
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Scroll reveal for sections
    var motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (motionOk && 'IntersectionObserver' in window) {
      var run = function () {
        var seen = [];
        // Only reveal top-level sections to avoid double-hiding nested content
        document.querySelectorAll('#MainContent > .shopify-section').forEach(function (el) {
          el.classList.add('im-reveal');
          seen.push(el);
        });
        if (!seen.length) return;
        var io = new IntersectionObserver(function (entries, obs) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('im-in');
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -8% 0px' });
        seen.forEach(function (el) { io.observe(el); });
      };
      if (document.readyState !== 'loading') run();
      else document.addEventListener('DOMContentLoaded', run);
    }
  })();
</script>
