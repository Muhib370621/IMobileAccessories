  <svg class="ic-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
  <svg class="ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.4"/><path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.6 4.6l1.8 1.8M17.6 17.6l1.8 1.8M4.6 19.4l1.8-1.8M17.6 6.4l1.8-1.8"/></svg>
</button>

<button class="im-top" id="im-top" type="button" aria-label="Back to top">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
</button>

<script>
  (function () {
    var root = document.documentElement;
    root.classList.add('imobile-ready');
    var motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Light/Dark mode ----
    var modeBtn = document.getElementById('im-mode');
    var savedMode = null;
    try { savedMode = localStorage.getItem('im-theme'); } catch (e) {}
    var isDark = savedMode ? savedMode === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
    root.classList.toggle('im-dark', isDark);
    if (modeBtn) modeBtn.addEventListener('click', function () {
      isDark = !isDark;
      root.classList.toggle('im-dark', isDark);
      try { localStorage.setItem('im-theme', isDark ? 'dark' : 'light'); } catch (e) {}
    });
    // Move the toggle into the header, right beside the search icon
    (function relocateToggle() {
      if (!modeBtn) return;
      var searchEl = document.querySelector('search-button') ||
                     document.querySelector('.header-actions__action') ||
                     document.querySelector('header button[aria-label*="earch"]');
      if (searchEl && searchEl.parentElement) {
        searchEl.parentElement.insertBefore(modeBtn, searchEl);
        modeBtn.classList.add('im-mode--header');
      }
    })();

    // ---- WhatsApp toggle ----
    var wa = document.getElementById('im-wa');
    var toggle = document.getElementById('im-wa-toggle');
    if (wa && toggle) {
      toggle.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = wa.classList.toggle('im-open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', function (e) {
        if (!wa.contains(e.target)) { wa.classList.remove('im-open'); toggle.setAttribute('aria-expanded', 'false'); }
      });
    }

    // ---- Back to top + sticky header shadow ----
    var topBtn = document.getElementById('im-top');
    function onScroll() {
      var y = window.pageYOffset || document.documentElement.scrollTop;
      if (topBtn) topBtn.classList.toggle('im-show', y > 500);
      root.classList.toggle('im-scrolled', y > 20);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
    if (topBtn) topBtn.addEventListener('click', function () { window.scrollTo({ top: 0, behavior: motionOk ? 'smooth' : 'auto' }); });

    // ---- Scroll reveal (top-level sections, every page) ----
    if ('IntersectionObserver' in window) {
      var run = function () {
        var targets = document.querySelectorAll('#MainContent > .shopify-section, .shopify-section.im-reveal-add');
        if (!targets.length) return;
        var io = new IntersectionObserver(function (entries, obs) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) { entry.target.classList.add('im-in'); obs.unobserve(entry.target); }
          });
        }, { threshold: 0.06, rootMargin: '0px 0px -6% 0px' });
        targets.forEach(function (el) { el.classList.add('im-reveal'); io.observe(el); });
        // Safety net: never leave anything hidden
        setTimeout(function () {
          document.querySelectorAll('.im-reveal:not(.im-in)').forEach(function (el) { el.classList.add('im-in'); });
        }, 2500);
      };
      if (document.readyState !== 'loading') run();
      else document.addEventListener('DOMContentLoaded', run);
      // Re-run after Shopify section re-renders (filters, pagination)
      document.addEventListener('shopify:section:load', run);
    }
  })();
</script>
