{%- comment -%}
  iMobile Accessories — global enhancements (loads on EVERY page)
  - Floating WhatsApp contact (both numbers)
  - Rich, elegant animations: scroll reveal + stagger, hover, image zoom,
    button shine, sticky-header shadow, nav underline, back-to-top, page fade
  Progressive-enhancement: animations only activate once JS adds `imobile-ready`
  to <html>, and a safety timer reveals everything after 2.5s so nothing is
  ever permanently hidden.
{%- endcomment -%}

{%- comment -%} Robotic font pairing: Orbitron (headings) + Rajdhani (body/UI) {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;600;700;800&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --im-wa-green: #25D366;
    --im-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --im-accent: #d90429;
    --im-accent-dark: #7a0216;
    --im-black: #0d0d0f;
    /* Override theme font variables site-wide (robotic look) */
    --font-heading--family: 'Orbitron', sans-serif;
    --font-subheading--family: 'Rajdhani', sans-serif;
    --font-body--family: 'Rajdhani', sans-serif;
    --font-accent--family: 'Rajdhani', sans-serif;
    --font-primary--family: 'Rajdhani', sans-serif;
  }
  body { font-family: 'Rajdhani', sans-serif; }
  h1, h2, h3, .h1, .h2, .h3 { font-family: 'Orbitron', sans-serif !important; letter-spacing: 0.01em; }
  body, p, a, span, li, input, select, textarea, button { font-family: 'Rajdhani', sans-serif; }

  /* ---------- Red/black skin: buttons get gradient + glow ---------- */
  .button:not(.button-secondary):not(.button-unstyled):not([class*="quantity"]):not([class*="zoom"]),
  .shopify-payment-button__button--unbranded,
  .improd__add button,
  .imfp__add {
    background: linear-gradient(120deg, var(--im-accent) 0%, var(--im-accent-dark) 100%) !important;
    background-size: 160% 160% !important;
    color: #fff !important;
    border-color: transparent !important;
    transition: background-position .4s var(--im-ease), transform .25s var(--im-ease), box-shadow .25s var(--im-ease) !important;
  }
  .button:not(.button-secondary):not(.button-unstyled):not([class*="quantity"]):not([class*="zoom"]):hover,
  .improd__add button:hover,
  .imfp__add:hover {
    background-position: 100% 50% !important;
    box-shadow: 0 12px 26px -10px rgba(217, 4, 41, 0.65) !important;
  }
  ::selection { background: var(--im-accent); color: #fff; }
  html { scrollbar-color: var(--im-accent) #16090b; }
  ::-webkit-scrollbar { width: 11px; }
  ::-webkit-scrollbar-track { background: #16090b; }
  ::-webkit-scrollbar-thumb { background: linear-gradient(180deg, var(--im-accent), var(--im-accent-dark)); border-radius: 8px; }

  /* ---------- Smooth cross-page transitions (modern browsers) ---------- */
  @view-transition { navigation: auto; }
  @keyframes imPageOut { to { opacity: 0; transform: translateY(-12px); } }
  @keyframes imPageIn { from { opacity: 0; transform: translateY(14px); } }
  ::view-transition-old(root) { animation: imPageOut .28s ease both; }
  ::view-transition-new(root) { animation: imPageIn .38s var(--im-ease) both; }

  html { scroll-behavior: smooth; }

  /* ---------- Page load fade ---------- */
  html.imobile-ready body { animation: imFadeIn 0.5s var(--im-ease) both; }
  @keyframes imFadeIn { from { opacity: 0; } to { opacity: 1; } }

  /* ---------- Scroll reveal (sections) ---------- */
  html.imobile-ready .im-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.75s var(--im-ease), transform 0.75s var(--im-ease);
    will-change: opacity, transform;
  }
  html.imobile-ready .im-reveal.im-in { opacity: 1; transform: none; }

  /* ---------- Staggered pop for grid items inside a revealed section ---------- */
  html.imobile-ready .im-reveal.im-in :is(
    .product-grid, .product-list__grid, ul[class*="product-grid"],
    .improd__grid, .imcat__grid, .imbn__grid, .imbn__right, .imtes__grid,
    .imft__grid, .imfg__grid, .imst__grid, .imcol__grid, .imtrust__grid
  ) > * {
    animation: imPop 0.55s var(--im-ease) both;
  }
  @keyframes imPop { from { opacity: 0; transform: translateY(22px) scale(0.98); } to { opacity: 1; transform: none; } }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imbn__grid, .imtes__grid, .imft__grid, .imfg__grid, .imst__grid, .imcol__grid, .imtrust__grid) > *:nth-child(1) { animation-delay: 0.04s; }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imbn__grid, .imtes__grid, .imft__grid, .imfg__grid, .imst__grid, .imcol__grid, .imtrust__grid) > *:nth-child(2) { animation-delay: 0.10s; }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imbn__grid, .imtes__grid, .imft__grid, .imfg__grid, .imst__grid, .imcol__grid, .imtrust__grid) > *:nth-child(3) { animation-delay: 0.16s; }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imbn__grid, .imtes__grid, .imft__grid, .imfg__grid, .imst__grid, .imcol__grid, .imtrust__grid) > *:nth-child(4) { animation-delay: 0.22s; }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imbn__grid, .imtes__grid, .imft__grid, .imfg__grid, .imst__grid, .imcol__grid, .imtrust__grid) > *:nth-child(5) { animation-delay: 0.28s; }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imbn__grid, .imtes__grid, .imft__grid, .imfg__grid, .imst__grid, .imcol__grid, .imtrust__grid) > *:nth-child(6) { animation-delay: 0.34s; }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imcol__grid) > *:nth-child(7) { animation-delay: 0.40s; }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imcol__grid) > *:nth-child(8) { animation-delay: 0.46s; }
  html.imobile-ready .im-reveal.im-in :is(.product-grid, .improd__grid, .imcat__grid, .imcol__grid) > *:nth-child(n+9) { animation-delay: 0.52s; }

  /* ---------- Premium hover: cards everywhere (incl. collection page) ---------- */
  .product-card, .card-gallery, .resource-card, .collection-card,
  .product-grid > li, .product-grid > div {
    transition: transform 0.4s var(--im-ease), box-shadow 0.4s var(--im-ease);
  }
  .product-card:hover, .resource-card:hover, .collection-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 42px -20px rgba(13, 13, 15, 0.32);
  }

  /* ---------- Image zoom on hover (cards + product gallery) ---------- */
  .product-card .media img, .card-gallery .media img, .resource-card .media img,
  .collection-card img, .product-media img, .product-media-container img,
  [class*="media-gallery"] img {
    transition: transform 0.65s var(--im-ease);
  }
  .product-card:hover .media img, .card-gallery:hover .media img,
  .resource-card:hover .media img, .collection-card:hover img,
  .product-media-container:hover img, [class*="media-gallery"] .media:hover img {
    transform: scale(1.07);
  }

  /* ---------- Buttons: lift + shine sweep (real buttons only, never unstyled/zoom/qty) ---------- */
  .button:not(.button-unstyled):not([class*="quantity"]):not([class*="zoom"]),
  .button-secondary,
  .shopify-payment-button__button {
    transition: transform 0.25s var(--im-ease), box-shadow 0.25s var(--im-ease), background-color 0.25s var(--im-ease), color 0.25s var(--im-ease) !important;
    position: relative;
    overflow: hidden;
  }
  .button:not(.button-unstyled):not([class*="quantity"]):not([class*="zoom"]):hover,
  .button-secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -10px rgba(217, 4, 41, 0.55);
  }
  .button:not(.button-unstyled):not([class*="quantity"]):not([class*="zoom"])::after {
    content: "";
    position: absolute; top: 0; left: -120%;
    width: 60%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.35), transparent);
    transform: skewX(-20deg);
    transition: left 0.6s var(--im-ease);
    pointer-events: none;
  }
  .button:not(.button-unstyled):not([class*="quantity"]):not([class*="zoom"]):hover::after { left: 140%; }

  /* ---------- Nav links: animated underline ---------- */
  .header__menu a, .header__inline-menu a, nav[class*="menu"] a {
    position: relative;
  }
  .header__menu a::after, .header__inline-menu a::after {
    content: ""; position: absolute; left: 0; bottom: -2px;
    width: 100%; height: 1.5px; background: currentColor;
    transform: scaleX(0); transform-origin: right;
    transition: transform 0.35s var(--im-ease);
  }
  .header__menu a:hover::after, .header__inline-menu a:hover::after {
    transform: scaleX(1); transform-origin: left;
  }

  /* ---------- Sticky header shadow on scroll ---------- */
  .im-scrolled #header-group, .im-scrolled header-component {
    box-shadow: 0 6px 24px -12px rgba(13, 13, 15, 0.28);
    transition: box-shadow 0.3s var(--im-ease);
  }

  /* ---------- Back to top ---------- */
  .im-top {
    position: fixed; left: 20px; bottom: 20px; z-index: 890;
    width: 46px; height: 46px; border-radius: 50%; border: none; cursor: pointer;
    background: var(--im-accent); color: #fff; display: grid; place-items: center;
    opacity: 0; visibility: hidden; transform: translateY(12px);
    box-shadow: 0 10px 24px -10px rgba(13,13,15,0.5);
    transition: opacity 0.3s var(--im-ease), transform 0.3s var(--im-ease), visibility 0.3s;
  }
  .im-top.im-show { opacity: 1; visibility: visible; transform: none; }
  .im-top:hover { transform: translateY(-3px); }
  .im-top svg { width: 20px; height: 20px; }
  .im-top { bottom: 76px; }
  @media (max-width: 749px) { .im-top { left: 14px; bottom: 124px; width: 42px; height: 42px; } }

  /* ---------- Light/Dark mode toggle ---------- */
  .im-mode {
    position: fixed; left: 20px; bottom: 20px; z-index: 890;
    width: 46px; height: 46px; border-radius: 50%; cursor: pointer;
    border: 1.5px solid rgba(127,127,132,.35);
    background: #fff; color: #0d0d0f; display: grid; place-items: center;
    box-shadow: 0 10px 24px -10px rgba(13,13,15,.4);
    transition: transform .25s var(--im-ease), background .3s, color .3s;
  }
  .im-mode:hover { transform: translateY(-3px) rotate(12deg); }
  .im-mode svg { width: 21px; height: 21px; }
  .im-mode .ic-sun { display: none; }
  html.im-dark .im-mode { background: #17181c; color: #ffd166; border-color: #2c2d33; }
  html.im-dark .im-mode .ic-sun { display: block; }
  html.im-dark .im-mode .ic-moon { display: none; }
  @media (max-width: 749px) { .im-mode { left: 14px; bottom: 70px; width: 42px; height: 42px; } }
  /* toggle relocated into the header, beside search */
  .im-mode--header, html.im-dark .im-mode--header {
    position: static; width: 40px; height: 40px;
    background: transparent; border: none; box-shadow: none;
    color: currentColor; display: inline-grid; place-items: center;
    margin-right: 2px;
  }
  .im-mode--header:hover { transform: rotate(18deg) scale(1.1); }
  html.im-dark .im-mode--header { color: #ffd166; }

  /* ---------- DARK MODE palette ---------- */
  html.im-dark { color-scheme: dark; }
  html.im-dark body { background: #0d0d0f; color: #dfe1e6; }
  html.im-dark .shopify-section, html.im-dark [class*="color-scheme"], html.im-dark [class*="color-"] {
    --color-background: #0d0d0f;
    --color-foreground: #dfe1e6;
    --color-foreground-heading: #ffffff;
    --color-border: #26272c;
  }
  html.im-dark section[id^="improd-"], html.im-dark section[id^="imtes-"],
  html.im-dark section[id^="imft-"], html.im-dark section[id^="imab-"],
  html.im-dark section[id^="imp2-"], html.im-dark section[id^="imfaq-"],
  html.im-dark section[id^="imbl-"], html.im-dark section[id^="imfg-"],
  html.im-dark section[id^="imbn-"], html.im-dark section[id^="imcat-"],
  html.im-dark section[id^="imfp-"] { background: #0f1013 !important; }
  html.im-dark .improd__card, html.im-dark .imtes__card, html.im-dark .imbl__card,
  html.im-dark [id^="imfaq-"] details, html.im-dark .imcat__card, html.im-dark .imfp__media {
    background: #17181c !important; border-color: #26272c !important;
  }
  html.im-dark .improd__media { background: #1c1d22 !important; }
  html.im-dark .improd__title, html.im-dark .improd__name, html.im-dark .improd__now,
  html.im-dark .imtes__title, html.im-dark .imtes__name,
  html.im-dark .imft__title, html.im-dark .imft__ftitle,
  html.im-dark .imab__title, html.im-dark .imfaq__title, html.im-dark [id^="imfaq-"] summary,
  html.im-dark .imbl__title, html.im-dark .imbl__ptitle, html.im-dark .imfg__title,
  html.im-dark .imbn__title, html.im-dark .imcat__title, html.im-dark .imcat__name,
  html.im-dark .imfp__title, html.im-dark .imfp__pname, html.im-dark .imfp__now,
  html.im-dark .im-empty__title { color: #f3f3f5 !important; }
  html.im-dark .imtes__quote, html.im-dark .imft__ftext, html.im-dark .imab__text,
  html.im-dark .imfaq__ans, html.im-dark .imfaq__sub, html.im-dark .imbl__excerpt,
  html.im-dark .imbn__sub, html.im-dark .imfp__desc, html.im-dark .imfp__sub,
  html.im-dark .im-empty__text { color: #a7abb4 !important; }
  html.im-dark .imft__ic { background: #202128 !important; color: #ff5a5f !important; }
  html.im-dark .imft__col { border-top-color: #26272c !important; }
  html.im-dark [id^="imfaq-"] .imfaq__plus::before, html.im-dark [id^="imfaq-"] .imfaq__plus::after { background: #ff5a5f; }
  html.im-dark .im-empty__art rect, html.im-dark .im-empty__art path:not([fill="#d90429"]) { opacity: .85; }

  /* ---------- Floating WhatsApp ---------- */
  .im-wa { position: fixed; right: 20px; bottom: 20px; z-index: 900; display: flex; flex-direction: column; align-items: flex-end; gap: 12px; }
  .im-wa__panel { display: flex; flex-direction: column; gap: 10px; max-height: 0; overflow: hidden; opacity: 0; transform: translateY(10px) scale(0.96); transform-origin: bottom right; transition: max-height 0.35s var(--im-ease), opacity 0.3s var(--im-ease), transform 0.35s var(--im-ease); pointer-events: none; }
  .im-wa.im-open .im-wa__panel { max-height: 220px; opacity: 1; transform: none; pointer-events: auto; }
  .im-wa__link { display: flex; align-items: center; gap: 10px; background: #ffffff; color: #0d0d0f; text-decoration: none; padding: 10px 16px 10px 12px; border-radius: 999px; font-family: var(--font-body--family, sans-serif); font-size: 0.9rem; font-weight: 600; box-shadow: 0 10px 30px -8px rgba(13, 13, 15, 0.35); white-space: nowrap; animation: imFadeIn 0.4s var(--im-ease) both; }
  .im-wa__link small { display: block; font-weight: 400; font-size: 0.72rem; opacity: 0.65; }
  .im-wa__link .im-wa__dot { width: 34px; height: 34px; flex: 0 0 34px; border-radius: 50%; background: var(--im-wa-green); display: grid; place-items: center; }
  .im-wa__link:hover { transform: translateX(-4px); transition: transform 0.25s var(--im-ease); }
  .im-wa__toggle { width: 60px; height: 60px; border-radius: 50%; border: none; cursor: pointer; background: var(--im-wa-green); color: #fff; display: grid; place-items: center; box-shadow: 0 12px 30px -6px rgba(37, 211, 102, 0.6); animation: imPulse 2.6s ease-in-out infinite; transition: transform 0.3s var(--im-ease); }
  .im-wa__toggle:hover { transform: scale(1.08); }
  .im-wa.im-open .im-wa__toggle { animation: none; }
  @keyframes imPulse { 0%, 100% { box-shadow: 0 12px 30px -6px rgba(37, 211, 102, 0.55), 0 0 0 0 rgba(37, 211, 102, 0.5); } 50% { box-shadow: 0 12px 30px -6px rgba(37, 211, 102, 0.55), 0 0 0 14px rgba(37, 211, 102, 0); } }

  @media (max-width: 749px) { .im-wa { right: 14px; bottom: 14px; } .im-wa__toggle { width: 54px; height: 54px; } }

  /* ============================================================
     GLASS THEME - red/black gradient + dotted backdrop, glassy UI
     ============================================================ */
  html {
    background:
      radial-gradient(1000px 560px at 88% -8%, rgba(217, 4, 41, 0.14), transparent 62%),
      radial-gradient(820px 560px at -8% 108%, rgba(13, 13, 15, 0.14), transparent 58%),
      linear-gradient(160deg, #fafafb 0%, #f1f2f4 100%) !important;
    background-attachment: fixed !important;
  }
  html.im-dark {
    background:
      radial-gradient(1000px 600px at 88% -8%, rgba(217, 4, 41, 0.30), transparent 62%),
      radial-gradient(820px 600px at -8% 108%, rgba(217, 4, 41, 0.12), transparent 55%),
      linear-gradient(160deg, #0a0a0b 0%, #121215 55%, #170a0d 100%) !important;
    background-attachment: fixed !important;
  }
  body, html.im-dark body { background: transparent !important; }
  body::before {
    content: ""; position: fixed; inset: 0; z-index: -1; pointer-events: none;
    background-image: radial-gradient(rgba(13, 13, 15, 0.10) 1px, transparent 1.4px);
    background-size: 26px 26px;
  }
  html.im-dark body::before {
    background-image: radial-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1.4px);
  }
  main .section-background { background: transparent !important; }
  section[id^="improd-"], section[id^="imtes-"], section[id^="imft-"],
  section[id^="imab-"], section[id^="imp2-"], section[id^="imfaq-"],
  section[id^="imbl-"], section[id^="imfg-"], section[id^="imbn-"],
  section[id^="imcat-"], section[id^="imfp-"],
  html.im-dark section[id^="improd-"], html.im-dark section[id^="imtes-"],
  html.im-dark section[id^="imft-"], html.im-dark section[id^="imab-"],
  html.im-dark section[id^="imp2-"], html.im-dark section[id^="imfaq-"],
  html.im-dark section[id^="imbl-"], html.im-dark section[id^="imfg-"],
  html.im-dark section[id^="imbn-"], html.im-dark section[id^="imcat-"],
  html.im-dark section[id^="imfp-"] { background: transparent !important; }
  .improd__card, .imtes__card, .imbl__card, [id^="imfaq-"] details,
  .imcat__card, .imfp__media, .imcd__unit, .imfp__qty, .im-wa__link {
    background: rgba(255, 255, 255, 0.55) !important;
    backdrop-filter: blur(14px) saturate(1.3);
    -webkit-backdrop-filter: blur(14px) saturate(1.3);
    border: 1px solid rgba(255, 255, 255, 0.5) !important;
    box-shadow: 0 8px 32px -12px rgba(13, 13, 15, 0.18);
  }
  html.im-dark .improd__card, html.im-dark .imtes__card, html.im-dark .imbl__card,
  html.im-dark [id^="imfaq-"] details, html.im-dark .imcat__card,
  html.im-dark .imfp__media, html.im-dark .imcd__unit, html.im-dark .imfp__qty,
  html.im-dark .im-wa__link {
    background: rgba(23, 24, 28, 0.55) !important;
    border: 1px solid rgba(255, 255, 255, 0.09) !important;
    box-shadow: 0 8px 32px -12px rgba(0, 0, 0, 0.55);
  }
  html.im-dark .im-wa__link { color: #e6e6e9; }
  .improd__media { background: rgba(127, 130, 140, 0.10) !important; }
  #header-group .shopify-section, #header-group .header,
  html.im-dark #header-group .shopify-section, html.im-dark #header-group .header {
    background: rgba(10, 10, 12, 0.58) !important;
    backdrop-filter: blur(18px) saturate(1.5);
    -webkit-backdrop-filter: blur(18px) saturate(1.5);
  }
  #header-group .header__row { background: transparent !important; }
  footer .shopify-section, html.im-dark footer .shopify-section {
    background: rgba(10, 10, 12, 0.62) !important;
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
  }

</style>

