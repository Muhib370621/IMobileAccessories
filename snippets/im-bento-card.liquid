{%- comment -%}
  iMobile bento tile. Params: block, big
  Link resolves to a collection matching the tile title (e.g. "Mobile Covers"
  -> /collections/mobile-covers) so only that category's products show.
  Falls back to a search for the title, then to the block's link.
{%- endcomment -%}
{%- liquid
  assign handle = block.settings.title | handleize
  assign coll = collections[handle]
  if coll != empty
    assign url = coll.url
  elsif block.settings.link != blank and block.settings.link != '/collections/all'
    assign url = block.settings.link
  else
    assign q = block.settings.title | url_encode
    assign url = routes.search_url | append: '?q=' | append: q
  endif
-%}
{%- liquid
  assign fallback_img = blank
  if coll != empty and coll.products.first.featured_image != blank
    assign fallback_img = coll.products.first.featured_image
  else
    assign pidx = idx | default: 0
    assign fallback_img = collections.all.products[pidx].featured_image
  endif
-%}
<a class="imbn__card{% if big %} imbn__card--big{% endif %}" href="{{ url }}" {{ block.shopify_attributes }}>
  {%- if block.settings.image != blank -%}
    <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
  {%- elsif coll != empty and coll.featured_image != blank -%}
    <img src="{{ coll.featured_image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
  {%- elsif fallback_img != blank -%}
    <img src="{{ fallback_img | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
  {%- else -%}
    <span class="imbn__ph"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="7" y="2" width="10" height="20" rx="2.5"/></svg></span>
  {%- endif -%}
  <span class="imbn__ov"></span>
  <span class="imbn__body">
    <span class="imbn__name">{{ block.settings.title }}</span>
    <span class="imbn__link">{{ block.settings.link_label | default: 'Shop Now' }} →</span>
  </span>
</a>
