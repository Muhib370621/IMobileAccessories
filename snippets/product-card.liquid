{%- comment -%} Product card. Param: product {%- endcomment -%}
{%- liquid
  assign v = product.selected_or_first_available_variant
  assign on_sale = false
  if v.compare_at_price > v.price
    assign on_sale = true
    assign pct = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round
  endif
-%}
<div class="card">
  <a class="card__media" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
    {%- if on_sale -%}<span class="card__badge">-{{ pct }}%</span>{%- endif -%}
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" width="600" height="600" loading="lazy">
    {%- else -%}
      <span class="ph">{% render 'icon', name: 'phone', size: 54 %}</span>
    {%- endif -%}
  </a>
  <div class="card__body">
    <a class="card__title" href="{{ product.url }}">{{ product.title }}</a>
    {% render 'price', target: v %}
    <div class="card__add">
      {%- if product.available -%}
        <form method="post" action="{{ routes.cart_add_url }}" data-product-form>
          <input type="hidden" name="id" value="{{ v.id }}">
          <button type="submit" class="btn btn--primary btn--block" data-add data-label="Add to Cart">Add to Cart</button>
        </form>
      {%- else -%}
        <button class="btn btn--outline btn--block" disabled>Sold Out</button>
      {%- endif -%}
    </div>
  </div>
</div>
