<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ page_title }}{% if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

    {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}

    {%- liquid
      assign body_font = settings.font_body
      assign heading_font = settings.font_heading
      assign heading_bold = heading_font | font_modify: 'weight', 'bolder'
    -%}
    {{ body_font | font_face: font_display: 'swap' }}
    {{ heading_font | font_face: font_display: 'swap' }}
    {{ heading_bold | font_face: font_display: 'swap' }}

    <style>
      :root {
        --bg: {{ settings.color_bg }};
        --text: {{ settings.color_text }};
        --heading: {{ settings.color_heading }};
        --accent: {{ settings.color_accent }};
        --accent-2: {{ settings.color_accent_2 }};
        --muted: {{ settings.color_muted }};
        --footer-bg: {{ settings.color_footer_bg }};
        --wa: #25D366;
        --radius: {{ settings.radius }}px;
        --card-radius: {{ settings.card_radius }}px;
        --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
        --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --font-body-weight: {{ body_font.weight }};
        --font-heading-weight: {{ heading_font.weight }};
        --page-width: 1360px;
        --ease: cubic-bezier(0.22, 1, 0.36, 1);
        --base-size: {{ settings.base_size }}px;
      }
    </style>

    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>
  </head>

  <body class="template-{{ template.name | handle }}">
    <a class="skip-link" href="#MainContent">{{ 'general.skip_to_content' | t | default: 'Skip to content' }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'cart-drawer' %}
    {% render 'floating-contact' %}

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
