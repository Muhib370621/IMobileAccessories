<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {%- if settings.favicon != blank -%}<link rel="icon" href="{{ settings.favicon | image_url: width: 32 }}">{%- endif -%}
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-password">
    <main style="min-height:100vh;display:grid;place-items:center;text-align:center;padding:40px 20px">
      <div style="max-width:460px">
        <h1>{{ shop.name }}</h1>
        <p style="color:#6a7280">{{ settings.tagline }}. Opening soon.</p>
        {{ content_for_layout }}
        {% form 'storefront_password' %}
          {%- if form.errors -%}<p style="color:#e11d48">{{ form.errors.messages.form }}</p>{%- endif -%}
          <div style="display:flex;gap:10px;justify-content:center;margin-top:16px">
            <input type="password" name="password" placeholder="Password" style="padding:12px 14px;border:1px solid var(--muted);border-radius:var(--radius)">
            <button type="submit" class="btn btn--primary">Enter</button>
          </div>
        {% endform %}
      </div>
    </main>
  </body>
</html>
